<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parlor Prediction</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ParlorPrediction.Mvc.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <div class="container app-shell">
            <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index">Parlor Prediction</a>
            <span class="app-badge">Clean Architecture Setup</span>
        </div>
    </header>
    <div class="container app-shell">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container app-shell footer-content">
            <span>&copy; 2026 Parlor Prediction</span>
            <span>Base interna para Dough Prep</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
