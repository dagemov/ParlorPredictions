@{
    var useDoughExperience = ViewData["UseDoughExperience"] is bool enabled && enabled;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parlor Prediction</title>
    <script type="importmap"></script>
    @if (useDoughExperience)
    {
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />
        <script>
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            tertiary: "#132600",
                            "inverse-primary": "#adc7f7",
                            "tertiary-fixed": "#bbf37c",
                            "surface-dim": "#ddd9d6",
                            surface: "#fdf9f6",
                            secondary: "#904d00",
                            "on-secondary-fixed-variant": "#6e3900",
                            "tertiary-container": "#223d00",
                            "on-tertiary-fixed": "#0f2000",
                            "primary-container": "#1a365d",
                            "inverse-surface": "#31302f",
                            "surface-tint": "#455f88",
                            "on-surface": "#1c1b1a",
                            "secondary-container": "#fe932c",
                            "on-background": "#1c1b1a",
                            outline: "#74777f",
                            "on-primary-fixed": "#001b3c",
                            "on-error-container": "#93000a",
                            "on-error": "#ffffff",
                            "on-surface-variant": "#43474e",
                            "on-secondary-container": "#663500",
                            "inverse-on-surface": "#f4f0ed",
                            "tertiary-fixed-dim": "#a0d663",
                            "surface-container-low": "#f7f3f0",
                            "error-container": "#ffdad6",
                            "primary-fixed-dim": "#adc7f7",
                            "on-tertiary-fixed-variant": "#2e4f00",
                            primary: "#002045",
                            background: "#fdf9f6",
                            "on-secondary-fixed": "#2f1500",
                            "surface-container": "#f1edea",
                            "surface-container-highest": "#e5e2df",
                            "on-primary-container": "#86a0cd",
                            "on-tertiary": "#ffffff",
                            "on-primary": "#ffffff",
                            "surface-bright": "#fdf9f6",
                            "surface-container-high": "#ebe7e4",
                            "on-tertiary-container": "#7aad3f",
                            "surface-variant": "#e5e2df",
                            "primary-fixed": "#d6e3ff",
                            "on-primary-fixed-variant": "#2d476f",
                            "secondary-fixed": "#ffdcc3",
                            "secondary-fixed-dim": "#ffb77d",
                            "on-secondary": "#ffffff",
                            error: "#ba1a1a",
                            "outline-variant": "#c4c6cf",
                            "surface-container-lowest": "#ffffff"
                        },
                        borderRadius: {
                            DEFAULT: "0.25rem",
                            lg: "0.5rem",
                            xl: "0.75rem",
                            full: "9999px"
                        },
                        spacing: {
                            "container-padding": "32px",
                            unit: "8px",
                            "touch-target-min": "56px",
                            gutter: "24px"
                        },
                        fontFamily: {
                            "status-lg": ["Inter", "sans-serif"],
                            "label-caps": ["Inter", "sans-serif"],
                            "headline-lg": ["Inter", "sans-serif"],
                            "status-hero": ["Inter", "sans-serif"],
                            "body-lg": ["Inter", "sans-serif"],
                            "headline-md": ["Inter", "sans-serif"]
                        },
                        fontSize: {
                            "status-lg": ["48px", { lineHeight: "56px", letterSpacing: "-0.01em", fontWeight: "700" }],
                            "label-caps": ["14px", { lineHeight: "20px", letterSpacing: "0.05em", fontWeight: "700" }],
                            "headline-lg": ["32px", { lineHeight: "40px", fontWeight: "600" }],
                            "status-hero": ["72px", { lineHeight: "80px", letterSpacing: "-0.02em", fontWeight: "700" }],
                            "body-lg": ["20px", { lineHeight: "28px", fontWeight: "400" }],
                            "headline-md": ["24px", { lineHeight: "32px", fontWeight: "600" }]
                        }
                    }
                }
            };
        </script>
        <style>
            .material-symbols-outlined {
                font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
                vertical-align: middle;
            }
        </style>
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true" />
    @if (useDoughExperience)
    {
        <link rel="stylesheet" href="~/css/dough-quality.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="~/ParlorPrediction.Mvc.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="pp-shell-body">
    @{
        var canSeePrep = User.Identity?.IsAuthenticated == true &&
            (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("PizzaMaker"));
        var canSeeHome = canSeePrep;
        var canSeeAdminPanel = User.Identity?.IsAuthenticated == true &&
            (User.IsInRole("Admin") || User.IsInRole("Manager"));
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
        var isSessionPage = string.Equals(currentController, "Session", StringComparison.OrdinalIgnoreCase);
        var showSidebar = User.Identity?.IsAuthenticated == true && !isSessionPage;
        var isPublicHome = !showSidebar && string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);
        var roleLabel = User.IsInRole("Admin")
            ? "Admin"
            : User.IsInRole("Manager")
                ? "Manager"
                : User.IsInRole("PizzaMaker")
                    ? "PizzaMaker"
                    : "Guest";
        var displayName = User.Identity?.Name ?? "Parlor User";
        var brandController = canSeeHome ? "Home" : canSeePrep ? "Prep" : "Home";
        var brandAction = canSeeHome ? "Index" : canSeePrep ? "Dough" : "Index";
        var isPrepRoute =
            string.Equals(currentController, "Prep", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(currentController, "DoughUsage", StringComparison.OrdinalIgnoreCase);
        var isDoughInventoryRoute = string.Equals(currentController, "DoughInventory", StringComparison.OrdinalIgnoreCase);

        string NavLinkClass(string controller, string? action = null)
        {
            var controllerMatches = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
            var actionMatches = string.IsNullOrWhiteSpace(action) ||
                string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
            return controllerMatches && actionMatches
                ? "pp-nav-link is-active"
                : "pp-nav-link";
        }

        var adminPanelNavClass =
            (string.Equals(currentController, "AdminPanel", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentController, "AdminUsers", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentController, "PrepData", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentController, "PrepRecommendations", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentController, "WeeklyClosing", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentController, "DailyClosing", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentController, "DoughQuality", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentController, "Dashboard", StringComparison.OrdinalIgnoreCase))
            ? "pp-nav-link is-active"
            : "pp-nav-link";
    }

    <div class="pp-shell">
        <header class="pp-topbar">
            <a class="pp-topbar__brand" asp-controller="@brandController" asp-action="@brandAction">
                <span class="pp-topbar__mark">PP</span>
                <span>
                    <strong>Parlor Prediction</strong>
                    <small>Kitchen workflow system</small>
                </span>
            </a>

            <div class="pp-topbar__meta">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="pp-chip">
                        <i class="fa-regular fa-calendar"></i>
                        @DateTime.Today.ToString("MMM dd, yyyy")
                    </span>
                    <span class="pp-chip--outline">
                        <i class="fa-solid fa-user-shield"></i>
                        @roleLabel
                    </span>
                    <span class="pp-chip--outline">
                        <i class="fa-regular fa-user"></i>
                        @displayName
                    </span>
                    <form asp-controller="Session" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            <i class="fa-solid fa-right-from-bracket me-2"></i>
                            Sign Out
                        </button>
                    </form>
                }
                else
                {
                    if (!isPublicHome)
                    {
                        <a class="btn btn-outline-secondary btn-sm" asp-controller="Home" asp-action="Index">
                            <i class="fa-solid fa-house me-2"></i>
                            Home
                        </a>
                    }
                    if (!string.Equals(currentAction, "Login", StringComparison.OrdinalIgnoreCase))
                    {
                        <a class="btn btn-outline-secondary btn-sm" asp-controller="Session" asp-action="Login">
                            Sign In
                        </a>
                    }
                    if (!string.Equals(currentAction, "Register", StringComparison.OrdinalIgnoreCase))
                    {
                        <a class="btn btn-primary btn-sm" asp-controller="Session" asp-action="Register">
                            Create Account
                        </a>
                    }
                }
            </div>
        </header>

        <div class="pp-frame">
            @if (showSidebar)
            {
                <aside class="pp-sidebar" aria-label="Primary">
                    <div class="pp-sidebar__section">
                        <span class="pp-sidebar__eyebrow">Navigation</span>
                        <p class="pp-sidebar__copy">Keep the product simple: one home view, one kitchen workflow, and one admin area.</p>
                    </div>
                    <nav class="pp-sidebar__nav">
                        @if (canSeeHome)
                        {
                            <a class="@NavLinkClass("Home", "Index")" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house"></i>
                                Home
                            </a>
                        }
                        @if (canSeePrep)
                        {
                            <a class="@(isPrepRoute ? "pp-nav-link is-active" : "pp-nav-link")" asp-controller="Prep" asp-action="Dough">
                                <i class="fa-solid fa-bread-slice"></i>
                                Dough Prep
                            </a>
                            <a class="@(isDoughInventoryRoute ? "pp-nav-link is-active" : "pp-nav-link")" asp-controller="DoughInventory" asp-action="Index">
                                <i class="fa-solid fa-box-open"></i>
                                Dough Inventory
                            </a>
                        }
                        @if (canSeeAdminPanel)
                        {
                            <a class="@adminPanelNavClass" asp-controller="AdminPanel" asp-action="Index">
                                <i class="fa-solid fa-screwdriver-wrench"></i>
                                Admin Panel
                            </a>
                        }
                    </nav>
                </aside>
            }

            <main class="pp-main @(showSidebar ? string.Empty : (isSessionPage ? "pp-main--session" : "pp-main--public"))" role="main">
                <div class="pp-page">
                    @RenderBody()
                </div>
            </main>
        </div>

        <footer class="pp-footer">
            <span>&copy; 2026 Parlor Prediction</span>
            <span>Shared workflow shell for kitchen planning, dough prep, and team operations.</span>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (useDoughExperience)
    {
        <script src="~/js/dough-quality.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
