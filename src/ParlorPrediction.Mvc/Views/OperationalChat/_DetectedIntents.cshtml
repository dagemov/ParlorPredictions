@model OperationalChatTurnViewModel

<section class="rounded-[20px] border border-outline-variant bg-surface-container-low p-5">
    <p class="m-0 text-sm font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Detected Domains</p>

    @if (Model.DetectedIntents.Count == 0)
    {
        <p class="mt-4 mb-0 text-sm leading-6 text-on-surface-variant">No operational intents were detected yet.</p>
    }
    else
    {
        <div class="mt-4 space-y-3">
            @foreach (var intent in Model.DetectedIntents)
            {
                <article class="rounded-[18px] border border-outline-variant bg-white p-4">
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="inline-flex rounded-full bg-primary-fixed px-3 py-1 text-xs font-extrabold uppercase tracking-[0.12em] text-primary">@intent.Domain</span>
                        <span class="inline-flex rounded-full bg-surface-container-high px-3 py-1 text-xs font-extrabold uppercase tracking-[0.12em] text-on-surface">@intent.IntentKind</span>
                        <span class="text-xs font-semibold uppercase tracking-[0.12em] text-on-surface-variant">@intent.EffectiveDate.ToString("ddd, MMM d")</span>
                    </div>
                    <p class="mt-3 mb-0 text-sm font-semibold text-on-surface">@intent.Decision</p>
                    <p class="mt-2 mb-0 text-sm leading-6 text-on-surface-variant">@intent.Summary</p>
                    @if (!string.IsNullOrWhiteSpace(intent.ClarificationPrompt))
                    {
                        <p class="mt-3 mb-0 text-sm font-semibold text-[#9b5200]">@intent.ClarificationPrompt</p>
                    }
                    <div class="mt-3 rounded-xl border border-outline-variant bg-surface-container-low px-4 py-3 text-sm leading-6 text-on-surface-variant">
                        @intent.SourceFragment
                    </div>
                </article>
            }
        </div>
    }
</section>
