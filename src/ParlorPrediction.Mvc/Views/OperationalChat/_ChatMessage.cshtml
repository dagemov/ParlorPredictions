@model OperationalChatTurnViewModel

<div class="space-y-4">
    <article class="ml-auto max-w-4xl rounded-[22px] border border-primary/15 bg-primary px-6 py-5 text-white shadow-sm">
        <p class="m-0 text-xs font-extrabold uppercase tracking-[0.16em] text-white/80">You</p>
        <p class="mt-3 mb-0 whitespace-pre-line text-base leading-7">@Model.UserMessage</p>
    </article>

    <article class="max-w-4xl rounded-[22px] border border-outline-variant bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
                <p class="m-0 text-xs font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Operational Chat</p>
                <h3 class="mt-2 text-2xl font-black tracking-[-0.03em] text-primary">@Model.AssistantSummary</h3>
            </div>
            @if (Model.CorrelationId != Guid.Empty)
            {
                <div class="rounded-full bg-primary-fixed px-4 py-2 text-xs font-extrabold uppercase tracking-[0.12em] text-primary">
                    Correlation @Model.CorrelationId
                </div>
            }
        </div>

        @if (Model.RequiresClarification && !string.IsNullOrWhiteSpace(Model.ClarificationPrompt))
        {
            <div class="mt-5 rounded-[20px] border border-[#c87917] bg-[#fff3e2] px-5 py-4 text-base font-semibold text-[#9b5200]">
                @Model.ClarificationPrompt
            </div>
        }

        <div class="mt-5 space-y-5">
            @await Html.PartialAsync("_DetectedIntents", Model)
            @await Html.PartialAsync("_CreatedDrafts", Model)
            @await Html.PartialAsync("_ChatWarnings", Model)
        </div>
    </article>
</div>
