@model OperationalDraftListPageViewModel
@{
    ViewData["Title"] = "Operational Drafts";
    var statusType = TempData["OperationalDraftsStatusType"] as string;
    var statusMessage = TempData["OperationalDraftsStatusMessage"] as string;
}

<section class="space-y-gutter">
    <header class="rounded-[28px] border border-outline-variant bg-white p-8 shadow-sm">
        <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Operational Drafts</p>
        <h1 class="mt-3 text-4xl font-black tracking-[-0.05em] text-primary lg:text-6xl">Review drafts before any real write happens.</h1>
        <p class="mt-4 max-w-4xl text-xl leading-9 text-on-surface-variant">
            This inbox is review-only. The UI never calculates operational truth, never writes through MCP,
            and never approves a draft without previewing risk, conflicts, and diff first.
        </p>
    </header>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        var toneClass = statusType == "success"
            ? "border-[#2e6e14] bg-[#eff8e7] text-[#2e6e14]"
            : "border-error bg-[#fdeceb] text-error";

        <div class="rounded-[22px] border px-5 py-4 text-base font-semibold @toneClass">@statusMessage</div>
    }

    <section class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-4">
            <div>
                <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Inbox</p>
                <h2 class="mt-2 text-3xl font-black tracking-[-0.04em] text-primary">Pending and recent operational drafts</h2>
            </div>
            <span class="inline-flex rounded-full bg-primary-fixed px-4 py-2 text-sm font-extrabold uppercase tracking-[0.12em] text-primary">
                @Model.Drafts.Count draft(s)
            </span>
        </div>

        <div class="mt-6">
            @await Html.PartialAsync("_OperationalDraftList", Model)
        </div>
    </section>
</section>
