@model OperationalDraftDetailsPageViewModel
@{
    ViewData["Title"] = "Operational Draft Review";
    var statusType = TempData["OperationalDraftsStatusType"] as string;
    var statusMessage = TempData["OperationalDraftsStatusMessage"] as string;
}

<section class="space-y-gutter max-w-7xl">
    <header class="rounded-[28px] border border-outline-variant bg-white p-8 shadow-sm">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Operational Draft Review</p>
                <h1 class="mt-3 text-4xl font-black tracking-[-0.05em] text-primary lg:text-6xl">@Model.DraftTypeDisplay</h1>
                <p class="mt-4 max-w-4xl text-xl leading-9 text-on-surface-variant">
                    Review the persisted draft, the current preview, warnings, diff, and audit trail before approving or rejecting anything.
                </p>
            </div>
            <a asp-action="Index" class="inline-flex h-touch-target-min items-center justify-center rounded-xl border border-outline-variant px-6 text-sm font-extrabold uppercase tracking-[0.14em] text-primary no-underline">
                Back To Inbox
            </a>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        var toneClass = statusType == "success"
            ? "border-[#2e6e14] bg-[#eff8e7] text-[#2e6e14]"
            : "border-error bg-[#fdeceb] text-error";

        <div class="rounded-[22px] border px-5 py-4 text-base font-semibold @toneClass">@statusMessage</div>
    }

    <section class="grid gap-5 lg:grid-cols-4">
        <article class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Status</p>
            <strong class="mt-4 block text-3xl font-black tracking-[-0.04em] text-primary">@Model.StatusDisplay</strong>
            <p class="mt-3 mb-0 text-base leading-7 text-on-surface-variant">Only safe drafts can move through approval.</p>
        </article>
        <article class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Correlation Id</p>
            <strong class="mt-4 block text-lg font-black tracking-[-0.02em] break-all text-primary">@Model.CorrelationId</strong>
            <p class="mt-3 mb-0 text-base leading-7 text-on-surface-variant">Shared trace id across simulation, draft, preview, and approval audit.</p>
        </article>
        <article class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Created By</p>
            <strong class="mt-4 block text-3xl font-black tracking-[-0.04em] text-primary">@Model.CreatedBy</strong>
            <p class="mt-3 mb-0 text-base leading-7 text-on-surface-variant">@Model.CreatedAtLocal.ToString("MMM d, yyyy h:mm tt")</p>
        </article>
        <article class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Reviewed</p>
            <strong class="mt-4 block text-2xl font-black tracking-[-0.04em] text-primary">@(Model.ReviewedByUserId ?? "Not yet")</strong>
            <p class="mt-3 mb-0 text-base leading-7 text-on-surface-variant">@(Model.ReviewedAtLocal?.ToString("MMM d, yyyy h:mm tt") ?? "No review decision has been saved yet.")</p>
        </article>
    </section>

    <section class="grid gap-5 xl:grid-cols-[1.1fr_0.9fr]">
        <article class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">1. Human Narrative</p>
            <div class="mt-4 rounded-[20px] border border-outline-variant bg-surface-container-low p-5 text-lg leading-8 text-on-surface">@Model.HumanNarrative</div>
        </article>

        <article class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">2. Draft Metadata</p>
            <dl class="mt-4 grid gap-4 sm:grid-cols-2">
                <div>
                    <dt class="text-sm font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Draft Id</dt>
                    <dd class="mt-1 break-all text-sm font-semibold text-on-surface">@Model.DraftId</dd>
                </div>
                <div>
                    <dt class="text-sm font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Draft Type</dt>
                    <dd class="mt-1 text-sm font-semibold text-on-surface">@Model.DraftTypeDisplay</dd>
                </div>
                <div>
                    <dt class="text-sm font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Status Reason</dt>
                    <dd class="mt-1 text-sm font-semibold text-on-surface">@(string.IsNullOrWhiteSpace(Model.StatusReason) ? "No review note saved." : Model.StatusReason)</dd>
                </div>
                <div>
                    <dt class="text-sm font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Current Status</dt>
                    <dd class="mt-1 text-sm font-semibold text-on-surface">@Model.StatusDisplay</dd>
                </div>
            </dl>
        </article>
    </section>

    <section class="grid gap-5 xl:grid-cols-2">
        <article class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">3. Normalized Interpretation</p>
            <pre class="mt-4 overflow-x-auto rounded-[20px] border border-outline-variant bg-surface-container-low p-5 text-sm leading-6 text-on-surface">@Model.NormalizedInterpretationJson</pre>
        </article>

        <article class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">4. Before Snapshot</p>
            <pre class="mt-4 overflow-x-auto rounded-[20px] border border-outline-variant bg-surface-container-low p-5 text-sm leading-6 text-on-surface">@Model.BeforeSnapshotJson</pre>
        </article>
    </section>

    <section class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
        <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">5. Persisted After Preview</p>
        <pre class="mt-4 overflow-x-auto rounded-[20px] border border-outline-variant bg-surface-container-low p-5 text-sm leading-6 text-on-surface">@Model.AfterPreviewJson</pre>
    </section>

    <section class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
                <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">6. Live Preview</p>
                <h2 class="mt-2 text-3xl font-black tracking-[-0.04em] text-primary">Current decision safety view</h2>
            </div>
            <button type="button"
                    class="inline-flex h-touch-target-min items-center justify-center rounded-xl border border-outline-variant px-6 text-sm font-extrabold uppercase tracking-[0.14em] text-primary"
                    hx-get="@Url.Action("Preview", "OperationalDrafts", new { id = Model.DraftId })"
                    hx-target="#operational-preview-panel"
                    hx-swap="innerHTML">
                Refresh Preview
            </button>
        </div>

        <div id="operational-preview-panel"
             class="mt-6"
             hx-get="@Url.Action("Preview", "OperationalDrafts", new { id = Model.DraftId })"
             hx-trigger="load"
             hx-swap="innerHTML">
            <div class="rounded-[20px] border border-outline-variant bg-surface-container-low px-5 py-6 text-base font-semibold text-on-surface-variant">
                Loading current preview...
            </div>
        </div>
    </section>

    <section class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm">
        <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">7. Audit Trail</p>
        <div class="mt-5 overflow-x-auto">
            <table class="min-w-full text-left">
                <thead>
                    <tr class="border-b border-outline-variant text-sm font-extrabold uppercase tracking-[0.14em] text-on-surface-variant">
                        <th class="px-3 py-3">Timestamp</th>
                        <th class="px-3 py-3">Action</th>
                        <th class="px-3 py-3">Actor</th>
                        <th class="px-3 py-3">Approved Entity</th>
                        <th class="px-3 py-3">Scope</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var entry in Model.AuditEntries)
                {
                    <tr class="border-b border-outline-variant/60 align-top text-sm text-on-surface">
                        <td class="px-3 py-3">@entry.TimestampLocal.ToString("MMM d, yyyy h:mm tt")</td>
                        <td class="px-3 py-3 font-semibold">@entry.ActionType</td>
                        <td class="px-3 py-3">@entry.ActorUserId</td>
                        <td class="px-3 py-3 font-mono">@(entry.ApprovedEntityId ?? "-")</td>
                        <td class="px-3 py-3">@(entry.IsForCurrentDraft ? "Draft" : "Correlation")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</section>
