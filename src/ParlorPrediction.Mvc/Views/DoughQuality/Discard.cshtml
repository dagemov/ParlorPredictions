@model DoughQualityDiscardPageViewModel
@{
    ViewData["Title"] = "Discard Dough";
    ViewData["DoughNav"] = "reviews";
    var statusType = TempData["DoughQualityStatusType"] as string;
    var statusMessage = TempData["DoughQualityStatusMessage"] as string;
}

<div class="dq-page dq-page--review">
    <section class="page-hero page-hero--compact dq-hero">
        <div>
            <span class="eyebrow">Manager Decision</span>
            <h1>Discard Dough</h1>
            <p class="page-copy dq-hero-copy">Use this screen only when dough is no longer safe or useful. A discard removes the dough from available inventory and logs the loss reason.</p>
        </div>
        <div class="hero-actions dq-action-bar">
            <a class="btn btn-outline-secondary"
               asp-controller="DoughQuality"
               asp-action="Review"
               asp-route-referenceDate="@Model.ReferenceDate.ToString("yyyy-MM-dd")">
                <i class="fa-regular fa-flag me-2"></i>
                Back to Review
            </a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-@statusType" role="alert">
            @statusMessage
        </div>
    }

    <section class="content-card content-card--padded dq-toolbar-card">
        <div class="section-heading">
            <span class="eyebrow">Live Dough Quality</span>
            <h2>Current dough quality totals</h2>
        </div>

        <partial name="_SummaryCards" model="Model.Summary" />
    </section>

    <section class="content-card content-card--padded dq-recommendation-card">
        <div class="section-heading">
            <span class="eyebrow">Step 1</span>
            <h2>Choose the dough to discard</h2>
            <p class="dq-section-copy">Only active dough records appear here. Once discarded, that dough no longer counts as available.</p>
        </div>

        @if (Model.Records.Count == 0)
        {
            <div class="empty-state dq-task-empty">
                <i class="fa-regular fa-circle-check"></i>
                <span>No active dough records are waiting for discard.</span>
            </div>
        }
        else
        {
            <div class="dq-review-grid">
                @foreach (var record in Model.Records)
                {
                    <article class="dq-review-card @(record.Id == Model.Form.DoughBatchQualityRecordId ? "dq-review-card--selected-outline" : string.Empty)">
                        <div class="dq-review-card__header">
                            <div>
                                <span class="dq-summary-card__label">Tracked dough</span>
                                <h3 class="dq-review-card__title">@record.Title</h3>
                            </div>
                            <span class="status-pill @(record.CountsAsAvailable ? "status-pill--success" : "status-pill--danger")">@record.DisplayStatus</span>
                        </div>
                        <div class="dq-review-card__stats">
                            <div class="dq-stat-box">
                                <span class="dq-stat-box__label">Quantity</span>
                                <span class="dq-stat-box__value">@record.QuantityBalls balls</span>
                            </div>
                            <div class="dq-stat-box">
                                <span class="dq-stat-box__label">Created</span>
                                <span class="dq-stat-box__value">@record.CreatedOrBalledAt.ToLocalTime().ToString("MMM d")</span>
                            </div>
                        </div>
                        <div class="dq-review-card__footer">
                            <a class="btn btn-outline-danger"
                               asp-action="Discard"
                               asp-controller="DoughQuality"
                               asp-route-recordId="@record.Id"
                               asp-route-referenceDate="@Model.ReferenceDate.ToString("yyyy-MM-dd")">
                                Select This Dough
                            </a>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="content-card content-card--padded dq-form-card">
        <div class="section-heading">
            <span class="eyebrow">Step 2</span>
            <h2>Record the discard</h2>
            <p class="dq-section-copy">The reason is required because these losses feed future reporting.</p>
        </div>

        @if (Model.SelectedRecord is null)
        {
            <div class="empty-state dq-task-empty">
                <i class="fa-regular fa-hand-point-up"></i>
                <span>Select one dough record first to open the discard form.</span>
            </div>
        }
        else
        {
            <div class="dq-form-layout">
                <partial name="_SelectedRecordPanel" model="Model.SelectedRecord" />

                <form asp-action="Discard" asp-controller="DoughQuality" method="post" class="dq-form-shell">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input asp-for="Form.DoughBatchQualityRecordId" type="hidden" />
                    <input asp-for="Form.ReferenceDate" type="hidden" />

                    <div class="dq-manager-banner dq-manager-banner--danger">
                        <span class="dq-manager-banner__eyebrow">Final action</span>
                        <h3>This dough will stop counting as available.</h3>
                        <p>Discard only when the dough is unsafe, spoiled, or no longer useful for service.</p>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Form.DiscardDate">Discard date</label>
                            <input asp-for="Form.DiscardDate" type="date" class="form-control" />
                            <span asp-validation-for="Form.DiscardDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="Form.DiscardReason">Reason</label>
                            <select asp-for="Form.DiscardReason" asp-items="Model.LossReasonOptions" class="form-select"></select>
                            <span asp-validation-for="Form.DiscardReason" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="Form.ManagerNote">Optional note</label>
                            <textarea asp-for="Form.ManagerNote" class="form-control" rows="4" placeholder="Explain what happened, if needed."></textarea>
                            <span asp-validation-for="Form.ManagerNote" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="dq-form-actions">
                        <button type="submit" class="btn btn-danger">
                            <i class="fa-regular fa-trash-can me-2"></i>
                            Confirm Discard
                        </button>
                        <a class="btn btn-outline-secondary"
                           asp-action="Reball"
                           asp-controller="DoughQuality"
                           asp-route-recordId="@Model.SelectedRecord.Id"
                           asp-route-referenceDate="@Model.ReferenceDate.ToString("yyyy-MM-dd")">
                            <i class="fa-solid fa-rotate-right me-2"></i>
                            Try Reball Instead
                        </a>
                    </div>
                </form>
            </div>
        }
    </section>
</div>
