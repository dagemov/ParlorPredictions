@model PrepDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-hero page-hero--compact">
    <div>
        <span class="eyebrow">Prep Dashboard</span>
        <h1>Today's dough picture at a glance.</h1>
        <p class="page-copy">Start from the same workflow shell the team already uses in Dough Prep, but with a faster manager view of what is covered, what is still missing, and where to act next.</p>
    </div>

    <div class="hero-actions">
        <form asp-action="Index" asp-controller="Dashboard" method="get" class="dashboard-date-form">
            <label class="visually-hidden" for="dashboardTargetDate">Target date</label>
            <input id="dashboardTargetDate"
                   name="targetDate"
                   type="date"
                   value="@Model.TargetDate.ToString("yyyy-MM-dd")"
                   class="form-control" />
            <button type="submit" class="btn btn-outline-secondary">
                <i class="fa-solid fa-calendar-day me-2"></i>
                Load Day View
            </button>
        </form>

        <a class="btn btn-primary" asp-controller="Prep" asp-action="Dough" asp-route-targetDate="@Model.TargetDate.ToString("yyyy-MM-dd")">
            <i class="fa-solid fa-bread-slice me-2"></i>
            Open Dough Prep
        </a>
    </div>
</section>

<div class="prep-grid prep-grid-wide">
    <section class="content-card content-card--padded">
        <div class="section-heading">
            <span class="eyebrow">Dough Summary</span>
            <h2>@Model.TargetDate.ToString("dddd, MMM d")</h2>
            @if (Model.HasRecommendation)
            {
                <p>The latest saved dough guidance for this date is reflected below.</p>
            }
            else
            {
                <p>No saved dough guidance exists for this date yet.</p>
            }
        </div>

        @if (Model.HasRecommendation)
        {
            <div class="metric-grid">
                <article class="metric-card">
                    <span class="metric-card__label">Expected Dough For The Day</span>
                    <strong>@Model.RequiredBalls</strong>
                    <small>Total dough expected for the selected day.</small>
                </article>
                <article class="metric-card">
                    <span class="metric-card__label">Current Dough Available</span>
                    <strong>@Model.AvailableBalls</strong>
                    <small>Dough counted in the saved guidance.</small>
                </article>
                <article class="metric-card">
                    <span class="metric-card__label">Dough Still Needed</span>
                    <strong>@Model.MissingBalls</strong>
                    <small>What still needs to be covered.</small>
                </article>
                <article class="metric-card">
                    <span class="metric-card__label">Cases To Plan</span>
                    <strong>@Model.RecommendedCases</strong>
                    <small>Rounded up from the dough still needed.</small>
                </article>
                <article class="metric-card">
                    <span class="metric-card__label">Full Batches To Plan</span>
                    <strong>@Model.RecommendedLoads</strong>
                    <small>Based on 14 cases per full dough batch.</small>
                </article>
            </div>

            <div class="recommendation-note">
                <h3>Latest dough guidance</h3>
                <p>@Model.LastRecommendationReason</p>
                @if (Model.LastRecommendationSavedAtUtc.HasValue)
                {
                    <small>Saved @Model.LastRecommendationSavedAtUtc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</small>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-regular fa-lightbulb"></i>
                <span>No dough guidance exists for this day yet. Generate one from Dough Prep.</span>
                <a class="btn btn-primary" asp-controller="Prep" asp-action="Dough" asp-route-targetDate="@Model.TargetDate.ToString("yyyy-MM-dd")">
                    <i class="fa-solid fa-arrow-right me-2"></i>
                    Go To Dough Prep
                </a>
            </div>
        }
    </section>

    <section class="content-card content-card--padded">
        <div class="section-heading">
            <span class="eyebrow">Task Snapshot</span>
            <h2>Dough tasks</h2>
            <p>Open work stays visible here so managers can see whether the guidance has already turned into real kitchen execution.</p>
        </div>

        <div class="dashboard-task-grid">
            <article class="metric-card">
                <span class="metric-card__label">Tasks Still Open</span>
                <strong>@Model.PendingTasks</strong>
                <small>Tasks still open or in progress for this day.</small>
            </article>
            <article class="metric-card">
                <span class="metric-card__label">Tasks Already Done</span>
                <strong>@Model.CompletedTasks</strong>
                <small>Tasks already closed for the selected day.</small>
            </article>
        </div>

        <div class="dashboard-note">
            <i class="fa-solid fa-circle-info"></i>
            <div>
                <strong>Need to act on this summary?</strong>
                <p>Open Dough Prep to calculate new guidance, save it, create a task, review older dough, or complete kitchen work.</p>
            </div>
        </div>
    </section>
</div>

<section class="content-card content-card--padded mt-4">
    <div class="section-heading">
        <span class="eyebrow">Weekly Dough Progress</span>
        <h2>@Model.TargetDate.ToString("MMM d") - @Model.WeeklyWindowEndDate.ToString("MMM d")</h2>
        <p>A simple week-ahead summary so the manager can see what is already covered and what still needs attention.</p>
    </div>

    <div class="metric-grid">
        <article class="metric-card">
            <span class="metric-card__label">Dough Needed This Week</span>
            <strong>@Model.WeeklyNeededBalls</strong>
            <small>Total dough from saved guidance in the next 7 days.</small>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">Dough Already Covered</span>
            <strong>@Model.WeeklyCoveredBalls</strong>
            <small>Dough already covered by saved availability.</small>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">Dough Still Pending</span>
            <strong>@Model.WeeklyPendingBalls</strong>
            <small>Dough that still needs coverage this week.</small>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">Tasks Completed</span>
            <strong>@Model.WeeklyCompletedTasks</strong>
            <small>Completed dough tasks across the weekly window.</small>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">Tasks Pending</span>
            <strong>@Model.WeeklyPendingTasks</strong>
            <small>Open dough tasks across the weekly window.</small>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">Upcoming Event Dough</span>
            <strong>@Model.WeeklyUpcomingEventBalls</strong>
            <small>Extra dough tied to active events in the next 7 days.</small>
        </article>
    </div>
</section>

<div class="stack-lg mt-4">
    <partial name="_AiRecommendationPartial" model="Model.AiRecommendation" />
</div>
