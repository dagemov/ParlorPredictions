@model DoughUsageEntryPageViewModel
@{
    ViewData["Title"] = "Record Dough Used";
    ViewData["DoughNav"] = "dough";
    var statusType = TempData["DoughUsageStatusType"] as string;
    var statusMessage = TempData["DoughUsageStatusMessage"] as string;
    var totalRemainingBalls = Model.AvailableSources.Sum(source => source.RemainingBalls);
    var totalOriginalBalls = Model.AvailableSources.Sum(source => source.OriginalBalls);
    var totalUsedBalls = Model.AvailableSources.Sum(source => source.UsedBalls);
    var tracedTodayBalls = Model.RecentTraces.Sum(trace => trace.BallsUsed);
    var useFirstBalls = Model.AvailableSources
        .Where(source => string.Equals(source.RecommendedAction, "UseFirst", StringComparison.OrdinalIgnoreCase))
        .Sum(source => source.RemainingBalls);
    var warningSourceCount = Model.AvailableSources.Count(source => source.HasWarning);
}

<section class="space-y-gutter">
    <section class="rounded-[28px] border border-outline-variant bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Trace Usage</p>
                <h1 class="mt-2 text-4xl font-black tracking-[-0.05em] text-primary lg:text-5xl">Record Dough Used</h1>
                <p class="mt-3 max-w-4xl text-lg leading-8 text-on-surface-variant">
                    Tell the system which dough source was used, how many cases moved, and where it went.
                    Daily Closing stays quantity-based. This screen explains the source.
                </p>
            </div>

            <div class="flex flex-wrap gap-3">
                <a asp-action="Dough"
                   asp-controller="Prep"
                   asp-route-targetDate="@Model.UsageDate.ToString("yyyy-MM-dd")"
                   class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-surface-container-highest no-underline">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Back To Dough Prep
                </a>
                <a asp-action="ReballPlanning"
                   asp-controller="DoughUsage"
                   asp-route-date="@Model.UsageDate.ToString("yyyy-MM-dd")"
                   class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl bg-primary text-on-primary font-bold hover:opacity-90 transition-opacity no-underline">
                    <span class="material-symbols-outlined">playlist_add_check</span>
                    Review Reball Plan
                </a>
                <a asp-action="Index"
                   asp-controller="DoughInventory"
                   asp-route-targetDate="@Model.UsageDate.ToString("yyyy-MM-dd")"
                   class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-surface-container-highest no-underline">
                    <span class="material-symbols-outlined">monitoring</span>
                    Dough Inventory
                </a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="mt-6 rounded-2xl border border-outline-variant bg-surface-container-low px-5 py-4 text-on-surface">
                <strong class="block text-sm uppercase tracking-[0.18em] text-on-surface-variant">@statusType</strong>
                <span class="mt-2 block text-base">@statusMessage</span>
            </div>
        }
    </section>

    @if (useFirstBalls > 0 || warningSourceCount > 0)
    {
        <section class="rounded-[24px] border-l-8 border-secondary-container bg-secondary-container/15 px-6 py-5">
            <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-4xl text-on-secondary-container">warning</span>
                <div>
                    <h2 class="m-0 text-2xl font-black tracking-[-0.03em] text-on-secondary-container">Use First</h2>
                    <p class="mt-2 mb-0 text-base leading-7 text-on-secondary-container">
                        @if (useFirstBalls > 0)
                        {
                            <span>@useFirstBalls balls are already flagged for first use today.</span>
                        }
                        @if (warningSourceCount > 0)
                        {
                            <span class="ms-2">@warningSourceCount source@(warningSourceCount == 1 ? string.Empty : "s") also carry operational warnings for summer or aging risk.</span>
                        }
                    </p>
                </div>
            </div>
        </section>
    }

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <article class="rounded-[24px] border border-outline-variant bg-white p-5 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Used Today</p>
            <strong class="mt-4 block text-5xl font-black tracking-[-0.05em] text-primary">@tracedTodayBalls</strong>
            <p class="mt-3 mb-0 text-sm leading-6 text-on-surface-variant">Balls already traced from real service movement on @Model.UsageDate.ToString("MMM d").</p>
        </article>
        <article class="rounded-[24px] border border-outline-variant bg-white p-5 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Live Remaining</p>
            <strong class="mt-4 block text-5xl font-black tracking-[-0.05em] text-[#2e6e14]">@totalRemainingBalls</strong>
            <p class="mt-3 mb-0 text-sm leading-6 text-on-surface-variant">Dough that still physically exists and can be selected from the source cards.</p>
        </article>
        <article class="rounded-[24px] border border-outline-variant bg-white p-5 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Use First</p>
            <strong class="mt-4 block text-5xl font-black tracking-[-0.05em] text-secondary">@useFirstBalls</strong>
            <p class="mt-3 mb-0 text-sm leading-6 text-on-surface-variant">Must-use and reballed dough stays visible here before newer dough is selected.</p>
        </article>
        <article class="rounded-[24px] border border-outline-variant bg-white p-5 shadow-sm">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Tracked Sources</p>
            <strong class="mt-4 block text-5xl font-black tracking-[-0.05em] text-on-surface">@Model.AvailableSources.Count</strong>
            <p class="mt-3 mb-0 text-sm leading-6 text-on-surface-variant">Each source card separates service days from the weekly Mon-Sun closing window.</p>
        </article>
    </section>

    <section class="grid gap-6 xl:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
        <section class="rounded-[28px] border border-outline-variant bg-white p-6 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Entry</p>
                    <h2 class="mt-2 text-3xl font-black tracking-[-0.04em] text-primary">Trace the service source</h2>
                    <p class="mt-2 text-base text-on-surface-variant">Service days stay Tue-Sun. Weekly closing stays Mon-Sun. 1 case = 12 balls, and half cases are allowed.</p>
                </div>
                <div class="rounded-2xl bg-surface-container px-5 py-4 text-right">
                    <span class="block text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Calculated Balls</span>
                    <strong class="block text-4xl font-black tracking-[-0.05em] text-primary">@Model.Form.BallsUsed</strong>
                </div>
            </div>

            <form asp-action="Create" asp-controller="DoughUsage" method="post" class="mt-6 space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

                <input asp-for="Form.DoughUsageTraceId" type="hidden" />
                <input asp-for="Form.IsEdit" type="hidden" />

                <div class="grid gap-4 md:grid-cols-2">
                    <div>
                        <label asp-for="Form.UsageDate" class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Usage Date</label>
                        <input asp-for="Form.UsageDate" type="date" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-white px-4" />
                        <span asp-validation-for="Form.UsageDate" class="mt-2 block text-sm text-red-700"></span>
                    </div>

                    <div>
                        <label asp-for="Form.Destination" class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Destination</label>
                        <select asp-for="Form.Destination" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-white px-4">
                            <option value="Restaurant">Restaurant</option>
                            <option value="Event">Event</option>
                            <option value="FarmersMarket">Farmers Market</option>
                        </select>
                        <span asp-validation-for="Form.Destination" class="mt-2 block text-sm text-red-700"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Form.SourceDoughBatchQualityRecordId" class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Source Dough</label>
                    <select asp-for="Form.SourceDoughBatchQualityRecordId" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-white px-4">
                        <option value="">Choose a source from the cards on the right</option>
                        @foreach (var source in Model.AvailableSources)
                        {
                            <option value="@source.SourceDoughBatchQualityRecordId">
                                @source.Title | @source.RemainingBalls balls remaining | @source.DisplaySourceType
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Form.SourceDoughBatchQualityRecordId" class="mt-2 block text-sm text-red-700"></span>
                </div>

                <div class="grid gap-4 md:grid-cols-[minmax(0,220px)_minmax(0,1fr)]">
                    <div>
                        <label asp-for="Form.TrayCount" class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Cases Used</label>
                        <input asp-for="Form.TrayCount" type="number" min="0.5" step="0.5" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-white px-4" />
                        <span asp-validation-for="Form.TrayCount" class="mt-2 block text-sm text-red-700"></span>
                    </div>

                    <div>
                        <label asp-for="Form.Notes" class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Notes</label>
                        <textarea asp-for="Form.Notes" rows="3" class="w-full rounded-xl border border-outline-variant bg-white px-4 py-3" placeholder="Optional note for the kitchen or manager."></textarea>
                    </div>
                </div>

                <div class="flex flex-wrap gap-3">
                    <button type="submit" class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl bg-primary text-on-primary font-bold hover:opacity-90 transition-opacity">
                        <span class="material-symbols-outlined">save</span>
                        @(Model.Form.IsEdit ? "Save Trace Correction" : "Save Dough Usage Trace")
                    </button>

                    <a asp-action="Create"
                       asp-controller="DoughUsage"
                       asp-route-date="@Model.UsageDate.ToString("yyyy-MM-dd")"
                       asp-route-destination="@Model.Form.Destination"
                       class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-surface-container-highest no-underline">
                        <span class="material-symbols-outlined">restart_alt</span>
                        Reset Form
                    </a>
                </div>
            </form>
        </section>

        <section class="rounded-[28px] border border-outline-variant bg-white p-6 shadow-sm">
            <div>
                <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Available Sources</p>
                <h2 class="mt-2 text-3xl font-black tracking-[-0.04em] text-primary">Choose the dough that actually moved</h2>
                <p class="mt-2 text-base text-on-surface-variant">Service days stay operational. Closing stays Mon-Sun. These cards only answer where the used dough came from.</p>
            </div>

            @if (Model.AvailableSources.Count > 0)
            {
                <div class="mt-6 grid gap-4 sm:grid-cols-3">
                    <div class="rounded-[20px] bg-surface-container-low p-4">
                        <span class="block text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Tracked Source Balls</span>
                        <strong class="mt-2 block text-3xl font-black tracking-[-0.05em] text-on-surface">@totalOriginalBalls</strong>
                    </div>
                    <div class="rounded-[20px] bg-surface-container-low p-4">
                        <span class="block text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Already Traced Used</span>
                        <strong class="mt-2 block text-3xl font-black tracking-[-0.05em] text-[#9b5200]">@totalUsedBalls</strong>
                    </div>
                    <div class="rounded-[20px] bg-surface-container-low p-4">
                        <span class="block text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Still Remaining</span>
                        <strong class="mt-2 block text-3xl font-black tracking-[-0.05em] text-primary">@totalRemainingBalls</strong>
                    </div>
                </div>
            }

            <div class="mt-6 space-y-4">
                @if (Model.AvailableSources.Count == 0)
                {
                    <div class="rounded-2xl bg-surface-container-low px-5 py-4 text-on-surface-variant">
                        No active dough sources are available for this date yet.
                    </div>
                }
                else
                {
                    @foreach (var source in Model.AvailableSources)
                    {
                        <article class="rounded-[24px] border @(source.IsSelected ? "border-primary bg-primary/5" : "border-outline-variant bg-surface-container-low") p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <h3 class="m-0 text-xl font-black tracking-[-0.03em] text-on-surface">@source.Title</h3>
                                    <p class="mt-1 text-sm uppercase tracking-[0.18em] text-on-surface-variant">@source.DisplaySourceType</p>
                                </div>
                                @if (source.IsPreferredSource)
                                {
                                    <span class="rounded-full bg-primary px-3 py-1 text-xs font-extrabold uppercase tracking-[0.18em] text-on-primary">Suggested First</span>
                                }
                            </div>

                            <div class="mt-4 grid gap-3 sm:grid-cols-3">
                                <div class="rounded-2xl bg-white px-4 py-3">
                                    <span class="block text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Remaining</span>
                                    <strong class="block text-3xl font-black tracking-[-0.05em] text-primary">@source.RemainingBalls</strong>
                                </div>
                                <div class="rounded-2xl bg-white px-4 py-3">
                                    <span class="block text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Already Used</span>
                                    <strong class="block text-2xl font-black tracking-[-0.04em] text-on-surface">@source.UsedBalls</strong>
                                </div>
                                <div class="rounded-2xl bg-white px-4 py-3">
                                    <span class="block text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Action</span>
                                    <strong class="block text-2xl font-black tracking-[-0.04em] text-on-surface">@source.DisplayRecommendedAction</strong>
                                </div>
                            </div>

                            <div class="mt-4">
                                <div class="mb-2 flex items-center justify-between text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">
                                    <span>Remaining By Source</span>
                                    <span>@source.RemainingPercent%</span>
                                </div>
                                <div class="h-3 overflow-hidden rounded-full bg-white">
                                    <div class="h-full bg-primary" style="width: @source.RemainingPercent%;"></div>
                                </div>
                            </div>

                            @if (source.UsedBalls > 0)
                            {
                                <div class="mt-3">
                                    <div class="mb-2 flex items-center justify-between text-xs font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">
                                        <span>Already Used</span>
                                        <span>@source.UsedPercent%</span>
                                    </div>
                                    <div class="h-3 overflow-hidden rounded-full bg-white">
                                        <div class="h-full bg-[#9b5200]" style="width: @source.UsedPercent%;"></div>
                                    </div>
                                </div>
                            }

                            <div class="mt-4 flex flex-wrap gap-3 text-sm text-on-surface-variant">
                                <span>Tracked balls: @source.OriginalBalls</span>
                                <span>Age: @source.AgeDays day@(source.AgeDays == 1 ? string.Empty : "s")</span>
                            </div>

                            @if (source.HasWarning && !string.IsNullOrWhiteSpace(source.WarningMessage))
                            {
                                <div class="mt-4 rounded-2xl border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-900">
                                    @source.WarningMessage
                                </div>
                            }
                        </article>
                    }
                }
            </div>
        </section>
    </section>

    <section class="rounded-[28px] border border-outline-variant bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Today&apos;s Traces</p>
                <h2 class="mt-2 text-3xl font-black tracking-[-0.04em] text-primary">What has already been logged</h2>
            </div>
            <p class="m-0 text-base text-on-surface-variant">This list helps managers confirm the source story behind Daily Closing totals.</p>
        </div>

        <div class="mt-6 space-y-4">
            @if (Model.RecentTraces.Count == 0)
            {
                <div class="rounded-2xl bg-surface-container-low px-5 py-4 text-on-surface-variant">
                    No usage traces have been recorded for this date yet.
                </div>
            }
            else
            {
                @foreach (var trace in Model.RecentTraces)
                {
                    <article class="rounded-[24px] border border-outline-variant bg-surface-container-low p-5">
                        <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                            <div>
                                <h3 class="m-0 text-xl font-black tracking-[-0.03em] text-on-surface">@trace.DisplayTrayCount @trace.CaseLabel from @trace.SourceDate.ToString("MMM d") dough</h3>
                                <p class="mt-1 text-sm uppercase tracking-[0.18em] text-on-surface-variant">@trace.DisplaySourceType for @trace.DisplayDestination</p>
                                <div class="mt-4 flex flex-wrap gap-4 text-sm text-on-surface-variant">
                                    <span>Balls used: @trace.BallsUsed</span>
                                    <span>Usage date: @trace.UsageDate.ToString("MMM d, yyyy")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(trace.Notes))
                                {
                                    <p class="mt-3 max-w-4xl text-sm leading-6 text-on-surface-variant">@trace.Notes</p>
                                }
                            </div>

                            @if (trace.CanManage)
                            {
                                <div class="flex flex-wrap gap-3">
                                    <a asp-action="Create"
                                       asp-controller="DoughUsage"
                                       asp-route-date="@trace.UsageDate.ToString("yyyy-MM-dd")"
                                       asp-route-destination="@trace.Destination"
                                       asp-route-traceId="@trace.Id"
                                       class="inline-flex items-center justify-center gap-2 h-12 px-5 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-white no-underline">
                                        <span class="material-symbols-outlined">edit</span>
                                        Correct
                                    </a>
                                    <form asp-action="Delete"
                                          asp-controller="DoughUsage"
                                          asp-route-id="@trace.Id"
                                          method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="usageDate" value="@trace.UsageDate.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="destination" value="@trace.Destination" />
                                        <button type="submit" class="inline-flex items-center justify-center gap-2 h-12 px-5 rounded-xl border border-red-300 text-red-700 font-bold hover:bg-red-50">
                                            <span class="material-symbols-outlined">delete</span>
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </article>
                }
            }
        </div>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
