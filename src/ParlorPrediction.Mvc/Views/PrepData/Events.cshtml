@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@model RestaurantEventListPageViewModel
@{
    ViewData["Title"] = "Restaurant Events";
    var requestToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<section class="page-hero page-hero--compact">
    <div>
        <span class="eyebrow">Prep Data</span>
        <h1>Restaurant events</h1>
        <p class="page-copy">Maintain private parties, rushes, and one-off demand spikes so Dough Prep can add them on top of the weekly baseline.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-@Model.StatusType status-banner" role="alert">
        @Model.StatusMessage
    </div>
}

<section class="content-card content-card--padded stack-lg">
    <div class="toolbar-header">
        <div class="section-heading mb-0">
            <span class="eyebrow">Filter Events</span>
            <h2>Search restaurant events</h2>
            <p>Use date filters or a text search to review private parties, special service windows, and any short-fermentation exceptions.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="PrepData">
                <i class="fa-solid fa-arrow-left me-2"></i>
                Prep Data Home
            </a>
            <a class="btn btn-primary" asp-action="CreateEvent" asp-controller="PrepData">
                <i class="fa-solid fa-plus me-2"></i>
                New Event
            </a>
        </div>
    </div>

    <input id="prep-events-anti-forgery" type="hidden" name="__RequestVerificationToken" value="@requestToken" />

    <form id="event-filters"
          asp-action="Events"
          asp-controller="PrepData"
          method="get"
          class="row g-3 align-items-end"
          hx-get="@Url.Action("Events", "PrepData")"
          hx-target="#restaurant-event-list"
          hx-swap="outerHTML"
          hx-push-url="true">
        <div class="col-md-3">
            <label class="form-label" for="fromDate">From date</label>
            <input id="fromDate"
                   name="fromDate"
                   type="date"
                   value="@Model.FromDate?.ToString("yyyy-MM-dd")"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label" for="toDate">To date</label>
            <input id="toDate"
                   name="toDate"
                   type="date"
                   value="@Model.ToDate?.ToString("yyyy-MM-dd")"
                   class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label" for="term">Search</label>
            <input id="term"
                   name="term"
                   type="text"
                   value="@Model.Term"
                   class="form-control"
                   placeholder="Private party, market, notes..." />
        </div>

        <div class="col-md-2">
            <div class="form-check admin-form-check">
                <input id="eventActiveOnly"
                       name="activeOnly"
                       class="form-check-input"
                       type="checkbox"
                       value="true"
                       checked="@Model.ActiveOnly" />
                <label class="form-check-label" for="eventActiveOnly">Active only</label>
            </div>
        </div>

        <div class="col-12">
            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-filter me-2"></i>
                    Search
                </button>
                <a class="btn btn-outline-secondary" asp-action="Events" asp-controller="PrepData">
                    Clear
                </a>
            </div>
        </div>
    </form>
</section>

<partial name="_RestaurantEventListPartial" model="Model" />
