@model ParlorPrediction.Mvc.Models.AdminDoughCorrections.AdminDoughBatchCorrectionFormViewModel
@{
    ViewData["Title"] = "Correct Dough Batch";
}

<section class="space-y-gutter">
    <header class="rounded-[28px] border border-outline-variant bg-white p-8 shadow-sm">
        <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Admin Correction</p>
        <h1 class="mt-3 text-4xl font-black tracking-[-0.05em] text-primary">Correct dough batch</h1>
        <p class="mt-4 max-w-4xl text-xl leading-9 text-on-surface-variant">Void orphan batches instead of deleting them so the history stays visible while planning stops counting them.</p>
    </header>

    <form method="post" class="rounded-[24px] border border-outline-variant bg-white p-6 shadow-sm space-y-5">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReferenceDate" />
        <div asp-validation-summary="ModelOnly" class="rounded-xl border border-error bg-[#fdeceb] px-4 py-3 text-sm text-error"></div>

        <div class="grid gap-5 md:grid-cols-2">
            <label class="block">
                <span class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Batch Id</span>
                <input value="@Model.DoughBatchId" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-surface-container-low px-4 font-mono" disabled />
            </label>
            <label class="block">
                <span class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Batch date</span>
                <input asp-for="BatchDate" type="date" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-white px-4" />
            </label>
            <label class="block">
                <span class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Total cases</span>
                <input asp-for="TotalCases" type="number" min="1" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-white px-4" />
            </label>
            <label class="block">
                <span class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Balled at</span>
                <input asp-for="BalledAtLocal" type="datetime-local" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-white px-4" />
            </label>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
            <label class="flex items-center gap-3 rounded-xl border border-outline-variant px-4 py-3">
                <input asp-for="IsBalled" type="checkbox" />
                <span class="text-sm font-extrabold uppercase tracking-[0.14em] text-on-surface">Is balled</span>
            </label>
            <label class="flex items-center gap-3 rounded-xl border border-outline-variant px-4 py-3">
                <input asp-for="IsEventException" type="checkbox" />
                <span class="text-sm font-extrabold uppercase tracking-[0.14em] text-on-surface">Event exception</span>
            </label>
            <label class="flex items-center gap-3 rounded-xl border border-outline-variant px-4 py-3">
                <input asp-for="IsVoided" type="checkbox" />
                <span class="text-sm font-extrabold uppercase tracking-[0.14em] text-on-surface">Void batch</span>
            </label>
        </div>

        <label class="block">
            <span class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Void reason</span>
            <input asp-for="VoidReason" class="h-touch-target-min w-full rounded-xl border border-outline-variant bg-white px-4" />
        </label>

        <label class="block">
            <span class="mb-2 block text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Notes</span>
            <textarea asp-for="Notes" rows="4" class="w-full rounded-xl border border-outline-variant bg-white px-4 py-3"></textarea>
        </label>

        <div class="flex flex-wrap gap-3">
            <button type="submit" class="inline-flex h-touch-target-min items-center rounded-xl bg-primary px-5 text-sm font-extrabold uppercase tracking-[0.14em] text-white">Save correction</button>
            <a asp-action="Index" asp-route-referenceDate="@Model.ReferenceDate.ToString("yyyy-MM-dd")" class="inline-flex h-touch-target-min items-center rounded-xl border border-outline-variant px-5 text-sm font-extrabold uppercase tracking-[0.14em] text-primary no-underline">Cancel</a>
        </div>
    </form>
</section>
