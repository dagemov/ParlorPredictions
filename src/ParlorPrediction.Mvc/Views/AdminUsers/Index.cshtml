@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@model ParlorPrediction.Mvc.Models.AdminUsers.AdminUserListPageViewModel
@{
    ViewData["Title"] = "User Management";
    var requestToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<section class="page-hero page-hero--compact">
    <div>
        <span class="eyebrow">Admin</span>
        <h1>User Management</h1>
        <p class="page-copy">Create, update, approve, and support the Parlor team without leaving the same workflow shell used by operations.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-@Model.StatusType status-banner" role="alert">
        @Model.StatusMessage
    </div>
}

<section class="content-card content-card--padded stack-lg">
    <div class="toolbar-header">
        <div class="section-heading mb-0">
            <span class="eyebrow">Team Directory</span>
            <h2>Search internal users</h2>
            <p>Find a user by name, email, or role, then jump into account details, status, or role management.</p>
        </div>

        <div class="pp-toolbar-actions">
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-arrow-left me-2"></i>
                Home
            </a>
            <a class="btn btn-primary" asp-action="Create" asp-controller="AdminUsers">
                <i class="fa-solid fa-user-plus me-2"></i>
                New User
            </a>
        </div>
    </div>

    <input id="admin-users-anti-forgery" type="hidden" name="__RequestVerificationToken" value="@requestToken" />

    <form id="admin-users-filters"
          asp-action="Index"
          asp-controller="AdminUsers"
          method="get"
          class="pp-filter-shell"
          hx-get="@Url.Action("Index", "AdminUsers")"
          hx-target="#admin-users-list"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="hidden" name="pendingOnly" value="@Model.PendingOnly.ToString().ToLowerInvariant()" />
        <div class="pp-filter-grid">
            <div>
                <label class="form-label" for="term">Search</label>
                <input id="term"
                       name="term"
                       type="text"
                       value="@Model.Term"
                       class="form-control"
                       placeholder="Name, email, or username..." />
            </div>

            <div>
                <label class="form-label" for="role">Role</label>
                <select id="role"
                        name="role"
                        class="form-select"
                        asp-items="Model.RoleOptions">
                </select>
            </div>

            <div class="form-check admin-form-check">
                <input id="activeOnly"
                       name="activeOnly"
                       class="form-check-input"
                       type="checkbox"
                       value="true"
                       checked="@Model.ActiveOnly" />
                <label class="form-check-label" for="activeOnly">Active only</label>
            </div>

            <div class="pp-toolbar-actions">
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-filter me-2"></i>
                    Search
                </button>
                <a class="btn @(Model.PendingOnly ? "btn-primary" : "btn-outline-secondary")"
                   asp-action="Index"
                   asp-controller="AdminUsers"
                   asp-route-pendingOnly="true">
                    Pending Users
                </a>
                <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="AdminUsers">
                    Clear
                </a>
            </div>
        </div>
    </form>

    @if (Model.PendingOnly)
    {
        <div class="recommendation-note">
            <h3>Pending user approval</h3>
            <p>These users confirmed their email but still need an Admin or Manager to assign an operational role and activate access.</p>
        </div>
    }
</section>

<partial name="_UserListPartial" model="Model" />
