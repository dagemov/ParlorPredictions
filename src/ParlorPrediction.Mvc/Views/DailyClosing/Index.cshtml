@model DailyDoughClosingIndexViewModel
@{
    ViewData["Title"] = "Daily Closing";
    ViewData["DoughNav"] = "daily-closing";
    var statusType = TempData["DailyClosingStatusType"] as string;
    var statusMessage = TempData["DailyClosingStatusMessage"] as string;
}

<section class="page-hero page-hero--compact">
    <div>
        <span class="eyebrow">Dough Recorrido</span>
        <h1>Daily Dough Closing</h1>
        <p class="page-copy">Track real dough usage against the daily forecast so the team can spot slow weeks and accumulating dough before weekly closing.</p>
    </div>

    <div class="hero-actions">
        <a class="btn btn-primary" asp-action="Close" asp-controller="DailyClosing" asp-route-closingDate="@Model.ReferenceDate.ToString("yyyy-MM-dd")">
            <i class="fa-solid fa-clipboard-check me-2"></i>
            Close Today
        </a>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="WeeklyClosing" asp-route-referenceDate="@Model.ReferenceDate.ToString("yyyy-MM-dd")">
            <i class="fa-solid fa-calendar-week me-2"></i>
            Weekly Closing
        </a>
        <a class="btn btn-outline-secondary" asp-action="Dough" asp-controller="Prep" asp-route-targetDate="@Model.ReferenceDate.ToString("yyyy-MM-dd")">
            <i class="fa-solid fa-bread-slice me-2"></i>
            Back To Dough Prep
        </a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(string.Equals(statusType, "success", StringComparison.OrdinalIgnoreCase) ? "alert-success" : "alert-danger") mt-4" role="alert">
        @statusMessage
    </div>
}

<section class="content-card content-card--padded mt-4">
    <div class="section-heading">
        <span class="eyebrow">Operational Week</span>
        <h2>@Model.WeekStartDate.ToString("MMM d") - @Model.WeekEndDate.ToString("MMM d")</h2>
        <p>Tuesday through Sunday. Each day compares forecast need against actual dough balls used.</p>
    </div>

    <form asp-action="Index" asp-controller="DailyClosing" method="get" class="row g-3 align-items-end mb-4">
        <div class="col-md-4">
            <label class="form-label" for="referenceDate">Reference date</label>
            <input id="referenceDate" name="referenceDate" type="date" value="@Model.ReferenceDate.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-secondary w-100">
                <i class="fa-solid fa-filter me-2"></i>
                Load Week
            </button>
        </div>
    </form>

    <div class="metric-grid mb-4">
        <article class="metric-card">
            <span class="metric-card__label">Accumulated Variance</span>
            <strong class="@(Model.AccumulatedVariance > 0 ? "text-success" : Model.AccumulatedVariance < 0 ? "text-danger" : string.Empty)">
                @(Model.AccumulatedVariance > 0 ? $"+{Model.AccumulatedVariance}" : Model.AccumulatedVariance.ToString())
            </strong>
            <small>Sum of daily forecast minus actual for closed days.</small>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">Total Actual Used</span>
            <strong>@Model.TotalActualUsedBalls</strong>
            <small>@Model.ClosedDaysCount day@(Model.ClosedDaysCount == 1 ? string.Empty : "s") closed so far.</small>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">Accumulated Surplus</span>
            <strong>@Model.AccumulatedSurplus</strong>
            <small>Days where usage ran below forecast.</small>
        </article>
        <article class="metric-card">
            <span class="metric-card__label">Accumulated Shortage</span>
            <strong>@Model.AccumulatedShortage</strong>
            <small>Days where usage ran above forecast.</small>
        </article>
    </div>

    @if (Model.HasSurplusWarning || Model.HasShortageWarning)
    {
        <div class="recommendation-note mb-4 @(Model.HasSurplusWarning ? "border-success" : "border-danger")">
            @if (Model.HasSurplusWarning)
            {
                <h3>Potential Dough Surplus: +@Model.ProjectedSurplus Balls</h3>
            }
            else
            {
                <h3>Potential Dough Shortage: @Model.ProjectedSurplus Balls</h3>
            }
            <p class="mb-0">@Model.Recommendation</p>
        </div>
    }
</section>

<section class="mt-4">
    <div class="section-heading mb-3">
        <span class="eyebrow">Daily Cards</span>
        <h2>Forecast vs actual by day</h2>
        <p>Positive difference means dough was used less than forecast. Negative means more was used than expected.</p>
    </div>

    <div class="row g-4">
        @foreach (var day in Model.Days)
        {
            var cardTone = day.IsClosed
                ? day.DailyVariance switch
                {
                    > 0 => "border-success",
                    < 0 => "border-danger",
                    _ => "border-outline-variant"
                }
                : day.IsFuture ? "border-outline-variant opacity-75" : "border-warning";

            <div class="col-12 col-md-6 col-xl-4">
                <article class="content-card content-card--padded @cardTone">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <span class="eyebrow">@day.Date.ToString("dddd")</span>
                            <h3 class="h4 mb-0">@day.Date.ToString("MMM d")</h3>
                        </div>
                        @if (day.IsToday)
                        {
                            <span class="badge bg-primary">Today</span>
                        }
                        else if (day.IsClosed)
                        {
                            <span class="badge bg-success">Closed</span>
                        }
                        else if (day.IsFuture)
                        {
                            <span class="badge bg-secondary">Upcoming</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Open</span>
                        }
                    </div>

                    <div class="metric-grid">
                        <article class="metric-card">
                            <span class="metric-card__label">Forecast Needed</span>
                            <strong>@day.ForecastNeededBalls</strong>
                            <small>balls</small>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Actual Used</span>
                            <strong>@(day.ActualUsedBalls?.ToString() ?? "—")</strong>
                            <small>balls</small>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Difference</span>
                            <strong class="@(day.DailyVariance > 0 ? "text-success" : day.DailyVariance < 0 ? "text-danger" : string.Empty)">@day.VarianceLabel</strong>
                            <small>forecast minus actual</small>
                        </article>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(day.Notes))
                    {
                        <p class="mt-3 mb-0 text-muted"><strong>Notes:</strong> @day.Notes</p>
                    }

                    <div class="mt-3">
                        @if (day.IsClosed && day.DailyClosingId.HasValue)
                        {
                            <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-controller="DailyClosing" asp-route-id="@day.DailyClosingId.Value">
                                <i class="fa-solid fa-pen-to-square me-1"></i>
                                Correct
                            </a>
                        }
                        else if (!day.IsFuture)
                        {
                            <a class="btn btn-primary btn-sm" asp-action="Close" asp-controller="DailyClosing" asp-route-closingDate="@day.Date.ToString("yyyy-MM-dd")">
                                <i class="fa-solid fa-clipboard-check me-1"></i>
                                Close Day
                            </a>
                        }
                    </div>
                </article>
            </div>
        }
    </div>
</section>
