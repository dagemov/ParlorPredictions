@model PrepTaskFormViewModel
@{
    ViewData["Title"] = Model.IsEditMode ? "Edit Dough Task" : "Create Dough Task";
}

<section class="page-hero page-hero--compact">
    <div>
        <span class="eyebrow">Dough Task</span>
        <h1>@(Model.IsEditMode ? "Update the dough task" : "Create a manual dough task")</h1>
        <p class="page-copy">Use clear kitchen quantities so the task reads the same way the team talks on the line.</p>
    </div>

    <div class="hero-actions">
        <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="PrepTasks" asp-route-taskDate="@Model.TaskDate.ToString("yyyy-MM-dd")">
            <i class="fa-solid fa-arrow-left me-2"></i>
            Back To Task Board
        </a>
    </div>
</section>

<section class="content-card content-card--padded">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <form asp-action="@(Model.IsEditMode ? "Edit" : "Create")"
          asp-controller="PrepTasks"
          asp-route-id="@Model.Id"
          method="post"
          class="stack-lg"
          data-dough-quantity-form
          data-dough-quantity-preview-mode="planned">
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="TaskDate" class="form-label"></label>
                <input asp-for="TaskDate" type="date" class="form-control" />
                <span asp-validation-for="TaskDate" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="PrepItemId" class="form-label">Prep Item</label>
                <select asp-for="PrepItemId" asp-items="Model.PrepItemOptions" class="form-select"></select>
                <span asp-validation-for="PrepItemId" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="PrepStationId" class="form-label">Prep Station</label>
                <select asp-for="PrepStationId" asp-items="Model.PrepStationOptions" class="form-select"></select>
                <span asp-validation-for="PrepStationId" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="AssignedRole" class="form-label">Assigned Role</label>
                <select asp-for="AssignedRole" asp-items="Model.AssignedRoleOptions" class="form-select"></select>
                <span asp-validation-for="AssignedRole" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="QuantityUnit" class="form-label">Quantity Type</label>
                <select asp-for="QuantityUnit" asp-items="Model.QuantityUnitOptions" class="form-select" data-dough-quantity-unit></select>
                <span asp-validation-for="QuantityUnit" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="QuantityValue" class="form-label">Quantity</label>
                <input asp-for="QuantityValue" type="number" min="1" class="form-control" data-dough-quantity-value />
                <span asp-validation-for="QuantityValue" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" rows="3" class="form-control" placeholder="Optional kitchen note"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
        </div>

        <div class="recommendation-note">
            <h3>Quantity Preview</h3>
            <p data-dough-quantity-preview>@Model.QuantityPreviewText</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="fa-regular fa-floppy-disk me-2"></i>
                @(Model.IsEditMode ? "Save Dough Task" : "Create Dough Task")
            </button>
            <a class="btn btn-outline-secondary" asp-action="Index" asp-controller="PrepTasks" asp-route-taskDate="@Model.TaskDate.ToString("yyyy-MM-dd")">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
