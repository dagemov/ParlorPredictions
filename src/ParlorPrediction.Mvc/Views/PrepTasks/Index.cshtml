@model PrepTaskListPageViewModel
@{
    ViewData["Title"] = "Dough Task Board";
    ViewData["DoughNav"] = "tasks";
    var statusType = TempData["PrepTaskStatusType"] as string;
    var statusMessage = TempData["PrepTaskStatusMessage"] as string;
    var selectedDate = Model.TaskDate?.ToString("yyyy-MM-dd");
    var urgentTasks = Model.Tasks.Where(task => task.CanComplete && task.NeedsAttentionNow).ToArray();
    var openTasks = Model.Tasks.Where(task => task.CanComplete && !task.NeedsAttentionNow).ToArray();
    var completedTasks = Model.Tasks.Where(task => string.Equals(task.Status, "Completed", StringComparison.OrdinalIgnoreCase)).ToArray();
}

<section class="space-y-gutter">
    <header class="flex flex-col xl:flex-row xl:items-end justify-between gap-6">
        <div>
            <p class="text-on-secondary-fixed-variant font-label-caps text-label-caps mb-1">Kitchen Decision Board</p>
            <h1 class="font-headline-lg text-headline-lg text-on-surface">Today's Dough Tasks</h1>
            <p class="font-body-lg text-on-surface-variant mt-2">Manage the shift's prep flow and keep `load made` separate from `balls available`.</p>
        </div>
        <div class="flex flex-wrap gap-3">
            @if (Model.CanManageTasks)
            {
                <a asp-action="Create" asp-controller="PrepTasks" class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl bg-primary text-on-primary font-bold hover:opacity-90 transition-opacity no-underline">
                    <span class="material-symbols-outlined">add</span>
                    Add New Task
                </a>
            }
            <a asp-action="Dough" asp-controller="Prep" asp-route-targetDate="@selectedDate" class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-surface-container-highest no-underline">
                <span class="material-symbols-outlined">bakery_dining</span>
                Back To Dough Prep
            </a>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="rounded-xl border @(string.Equals(statusType, "danger", StringComparison.OrdinalIgnoreCase) ? "border-error bg-error-container text-on-error-container" : "border-outline-variant bg-surface-container-low text-on-surface") px-5 py-4">
            @statusMessage
        </div>
    }

    <section class="bg-surface-container-low rounded-2xl border border-outline-variant p-6">
        <div class="mb-6">
            <p class="font-label-caps text-label-caps text-on-surface-variant mb-1">Filters</p>
            <h2 class="font-headline-md text-headline-md text-on-surface">Focus the board</h2>
        </div>

        <form asp-action="Index" asp-controller="PrepTasks" method="get" class="grid grid-cols-1 md:grid-cols-5 gap-4 items-end">
            <div>
                <label class="block text-on-surface-variant font-label-caps text-label-caps mb-2" asp-for="TaskDate"></label>
                <input asp-for="TaskDate" type="date" class="w-full h-touch-target-min rounded-xl border border-outline-variant bg-white px-4" />
            </div>
            <div>
                <label class="block text-on-surface-variant font-label-caps text-label-caps mb-2" asp-for="Status">Status</label>
                <select asp-for="Status" asp-items="Model.StatusOptions" class="w-full h-touch-target-min rounded-xl border border-outline-variant bg-white px-4"></select>
            </div>
            <div>
                <label class="block text-on-surface-variant font-label-caps text-label-caps mb-2" asp-for="AssignedRole">Assigned role</label>
                <select asp-for="AssignedRole" asp-items="Model.RoleOptions" class="w-full h-touch-target-min rounded-xl border border-outline-variant bg-white px-4"></select>
            </div>
            <div>
                <label class="block text-on-surface-variant font-label-caps text-label-caps mb-2" asp-for="PrepItemId">Prep item</label>
                <select asp-for="PrepItemId" asp-items="Model.PrepItemOptions" class="w-full h-touch-target-min rounded-xl border border-outline-variant bg-white px-4"></select>
            </div>
            <div class="flex flex-wrap gap-3">
                <button type="submit" class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">filter_alt</span>
                    Apply
                </button>
                <a asp-action="Index" asp-controller="PrepTasks" class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl border border-transparent text-on-surface-variant hover:bg-surface-container-highest no-underline">
                    Clear
                </a>
            </div>
        </form>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
        <article class="bg-white border border-outline-variant rounded-xl p-6">
            <div class="font-label-caps text-label-caps text-error mb-2">Must Do Now</div>
            <div class="font-status-lg text-status-lg text-error">@urgentTasks.Length</div>
            <div class="text-on-surface-variant mt-2">Pending ball dough or other work that needs attention now.</div>
        </article>
        <article class="bg-white border border-outline-variant rounded-xl p-6">
            <div class="font-label-caps text-label-caps text-secondary mb-2">Still Open</div>
            <div class="font-status-lg text-status-lg text-secondary">@openTasks.Length</div>
            <div class="text-on-surface-variant mt-2">Open dough work that is not completed yet.</div>
        </article>
        <article class="bg-white border border-outline-variant rounded-xl p-6">
            <div class="font-label-caps text-label-caps text-tertiary-container mb-2">Completed</div>
            <div class="font-status-lg text-status-lg text-tertiary-container">@completedTasks.Length</div>
            <div class="text-on-surface-variant mt-2">Tasks the team already finished for this view.</div>
        </article>
    </section>

    @if (Model.Tasks.Count == 0)
    {
        <div class="rounded-xl border border-dashed border-outline-variant bg-white p-10 text-center text-on-surface-variant">
            No dough tasks matched the current filters.
        </div>
    }
    else
    {
        <section class="grid grid-cols-1 xl:grid-cols-3 gap-gutter">
            <div class="space-y-4">
                <div class="flex items-center gap-3 px-1">
                    <div class="w-3 h-3 rounded-full bg-error"></div>
                    <h2 class="font-label-caps text-label-caps text-error tracking-widest uppercase">Must Do Now</h2>
                </div>
                @if (urgentTasks.Length == 0)
                {
                    <div class="rounded-xl border border-outline-variant bg-white p-6 text-on-surface-variant">Nothing urgent is waiting right now.</div>
                }
                else
                {
                    @foreach (var task in urgentTasks)
                    {
                        <partial name="_TaskBoardCard" model="task" />
                    }
                }
            </div>

            <div class="space-y-4">
                <div class="flex items-center gap-3 px-1">
                    <div class="w-3 h-3 rounded-full bg-secondary"></div>
                    <h2 class="font-label-caps text-label-caps text-secondary tracking-widest uppercase">Open Work</h2>
                </div>
                @if (openTasks.Length == 0)
                {
                    <div class="rounded-xl border border-outline-variant bg-white p-6 text-on-surface-variant">No additional open dough tasks are waiting.</div>
                }
                else
                {
                    @foreach (var task in openTasks)
                    {
                        <partial name="_TaskBoardCard" model="task" />
                    }
                }
            </div>

            <div class="space-y-4">
                <div class="flex items-center gap-3 px-1">
                    <div class="w-3 h-3 rounded-full bg-tertiary-fixed-dim"></div>
                    <h2 class="font-label-caps text-label-caps text-on-tertiary-fixed-variant tracking-widest uppercase">Completed</h2>
                </div>
                @if (completedTasks.Length == 0)
                {
                    <div class="rounded-xl border border-outline-variant bg-white p-6 text-on-surface-variant">Nothing has been completed yet.</div>
                }
                else
                {
                    @foreach (var task in completedTasks)
                    {
                        <article class="bg-white border border-outline-variant p-6 rounded-xl shadow-sm flex flex-col gap-4">
                            <div class="flex justify-between items-start gap-4">
                                <div>
                                    <div class="font-label-caps text-label-caps text-primary">@task.TaskTypeDisplayText</div>
                                    <h3 class="font-headline-md text-headline-md text-on-surface mt-1">@task.TaskTitle</h3>
                                    <p class="font-body-lg text-on-surface-variant mt-2">@task.StatusDetailText</p>
                                </div>
                                <span class="inline-flex items-center rounded-full px-4 py-2 text-sm font-bold uppercase bg-tertiary-fixed text-on-tertiary-fixed-variant">@task.Status</span>
                            </div>
                            <div class="grid grid-cols-2 gap-3">
                                <div class="rounded-xl bg-surface-container-low p-4">
                                    <div class="font-label-caps text-label-caps text-on-surface-variant mb-1">Needed</div>
                                    <div class="font-bold text-on-surface">@task.RecommendedQuantityText</div>
                                </div>
                                <div class="rounded-xl bg-surface-container-low p-4">
                                    <div class="font-label-caps text-label-caps text-on-surface-variant mb-1">Finished</div>
                                    <div class="font-bold text-on-surface">@task.CompletedQuantityText</div>
                                </div>
                            </div>
                            <div class="flex flex-wrap gap-3">
                                <a asp-action="Details" asp-controller="PrepTasks" asp-route-id="@task.PrepTaskId" class="inline-flex items-center justify-center gap-2 h-12 px-5 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-surface-container-highest no-underline">
                                    <span class="material-symbols-outlined">visibility</span>
                                    Details
                                </a>
                            </div>
                        </article>
                    }
                }
            </div>
        </section>
    }
</section>
