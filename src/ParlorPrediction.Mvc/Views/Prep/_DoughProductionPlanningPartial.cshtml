@model DoughProductionPlanningViewModel?

<section class="content-card content-card--padded">
    <div class="section-heading">
        <span class="eyebrow">Daily Operations</span>
        <h2>Today's Production Recommendation</h2>
        @if (Model is null)
        {
            <p>No production planning summary is available right now.</p>
        }
        else
        {
            <p>Work date: @Model.ProductionDate.ToString("dddd, MMM d"). This looks ahead @Model.DaysAhead days so the kitchen can mix dough before it is needed.</p>
        }
    </div>

    @if (Model is null)
    {
        <div class="empty-state">
            <i class="fa-regular fa-calendar"></i>
            <span>The system could not build a production plan for this work date.</span>
        </div>
    }
    else
    {
        <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="status-pill @(Model.HasProductionWorkToday ? "status-pill--warning" : "status-pill--success")">
                @(Model.HasProductionWorkToday ? "Kitchen Work Needed Today" : "No New Mixing Needed Today")
            </span>
            <span class="status-pill @(Model.RecommendedBallsToBallToday > 0 ? "status-pill--info" : "status-pill--neutral")">
                @(Model.RecommendedBallsToBallToday > 0 ? "Ball Existing Dough" : "No Extra Balling Today")
            </span>
        </div>

        <div class="metric-grid">
            <article class="metric-card">
                <span class="metric-card__label">Dough Needed Over The Next Week</span>
                <strong>@Model.TotalFutureRequiredBalls</strong>
                <small>Total dough expected across the planning window</small>
            </article>
            <article class="metric-card">
                <span class="metric-card__label">Current Dough Available</span>
                <strong>@Model.ReadyBalls</strong>
                <small>Dough already ready to use</small>
            </article>
            <article class="metric-card">
                <span class="metric-card__label">Still Fermenting</span>
                <strong>@Model.FermentingBalls</strong>
                <small>Dough already mixed and still aging</small>
            </article>
            <article class="metric-card">
                <span class="metric-card__label">Mixed But Not Balled</span>
                <strong>@Model.UnballedBalls</strong>
                <small>Dough that can be portioned today</small>
            </article>
            <article class="metric-card">
                <span class="metric-card__label">Dough To Mix Today</span>
                <strong>@Model.MissingBallsForProductionWindow</strong>
                <small>@Model.RecommendedCasesToMakeToday cases / @Model.RecommendedLoadsToMakeToday full batch@(Model.RecommendedLoadsToMakeToday == 1 ? string.Empty : "es")</small>
            </article>
            <article class="metric-card">
                <span class="metric-card__label">Balls To Prepare Today</span>
                <strong>@Model.RecommendedBallsToBallToday</strong>
                <small>Existing dough that should be balled now</small>
            </article>
        </div>

        <div class="recommendation-note">
            <h3>Why this daily plan matters</h3>
            <p>@Model.Reason</p>
        </div>

        @if (Model.HasUpcomingNeeds)
        {
            <div class="table-responsive mt-4">
                <table class="table prep-table align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Need Date</th>
                            <th scope="col">Usual Dough</th>
                            <th scope="col">Event Dough</th>
                            <th scope="col">Total Needed</th>
                            <th scope="col">Best Prep Window</th>
                            <th scope="col">Best Day To Mix</th>
                            <th scope="col">Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var need in Model.UpcomingNeeds)
                        {
                            <tr>
                                <td>
                                    <strong>@need.NeedDate.ToString("ddd, MMM d")</strong>
                                </td>
                                <td>@need.RestaurantBaselineBalls</td>
                                <td>@need.EventBalls</td>
                                <td><strong>@need.TotalRequiredBalls</strong></td>
                                <td>@need.ProductionWindowStart.ToString("MMM d") - @need.ProductionWindowEnd.ToString("MMM d")</td>
                                <td>
                                    <span class="status-pill @(need.IsRecommendedForSelectedProductionDate ? "status-pill--warning" : "status-pill--neutral")">
                                        @need.RecommendedMakeDate.ToString("MMM d")
                                    </span>
                                </td>
                                <td>
                                    @if (need.UsesShortFermentation)
                                    {
                                        <span class="inline-hint">
                                            <i class="fa-solid fa-sun"></i>
                                            Summer event timing
                                        </span>
                                    }
                                    else if (need.IsRecommendedForSelectedProductionDate)
                                    {
                                        <span class="inline-hint">
                                            <i class="fa-solid fa-circle-check"></i>
                                            Mix on this work date
                                        </span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</section>
