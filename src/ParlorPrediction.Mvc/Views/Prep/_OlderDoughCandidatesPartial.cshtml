@model DoughPrepPageViewModel
@{
    var candidates = Model.OlderDoughCandidates;
    var canManageQuality = User.IsInRole("Admin") || User.IsInRole("Manager");
    var canReball = canManageQuality || User.IsInRole("PizzaMaker");
}

<section class="rounded-[28px] border border-outline-variant bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Older Dough / Reball Candidates</p>
            <h2 class="mt-2 text-3xl font-black tracking-[-0.04em] text-primary">Review older dough without leaving the kitchen workflow.</h2>
            <p class="mt-3 max-w-4xl text-lg leading-8 text-on-surface-variant">
                Candidates appear when dough has reached the review window. Keep ready dough separate from mixed loads and decide what still needs attention.
            </p>
        </div>

        @if (canManageQuality)
        {
            <a asp-controller="DoughQuality"
               asp-action="Review"
               asp-route-referenceDate="@Model.TargetDate.ToString("yyyy-MM-dd")"
               class="inline-flex items-center justify-center gap-2 h-touch-target-min px-6 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-surface-container-highest no-underline">
                <span class="material-symbols-outlined">open_in_new</span>
                Advanced Review
            </a>
        }
    </div>

    @if (candidates.Count == 0)
    {
        <div class="mt-6 rounded-[22px] border border-dashed border-outline-variant bg-surface-container-low p-6 text-lg text-on-surface-variant">
            No older dough needs review on @Model.TargetDate.ToString("dddd, MMM d").
        </div>
    }
    else
    {
        <div class="mt-6 grid gap-4 xl:grid-cols-2">
            @foreach (var candidate in candidates)
            {
                <article class="rounded-[22px] border border-outline-variant bg-surface-container-low p-5">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div>
                            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Source day</p>
                            <h3 class="mt-2 mb-0 text-2xl font-bold tracking-[-0.03em] text-on-surface">@candidate.SourceDate.ToString("dddd, MMM d")</h3>
                            <p class="mt-3 mb-0 text-lg leading-8 text-on-surface-variant">@candidate.CandidateReason</p>
                        </div>
                        <span class="inline-flex rounded-full bg-white px-4 py-2 text-sm font-bold uppercase tracking-[0.08em] text-primary">@candidate.AgeDays day@(candidate.AgeDays == 1 ? string.Empty : "s") old</span>
                    </div>

                    <div class="mt-5 grid gap-3 md:grid-cols-3">
                        <div class="rounded-[18px] bg-white p-4">
                            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Quantity</p>
                            <strong class="mt-3 block text-2xl font-black tracking-[-0.04em] text-on-surface">@candidate.QuantityBalls balls</strong>
                        </div>
                        <div class="rounded-[18px] bg-white p-4">
                            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Current Status</p>
                            <strong class="mt-3 block text-2xl font-black tracking-[-0.04em] text-on-surface">@candidate.DisplayStatus</strong>
                        </div>
                        <div class="rounded-[18px] bg-white p-4">
                            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.16em] text-on-surface-variant">Availability</p>
                            <strong class="mt-3 block text-lg font-bold text-on-surface">@candidate.AvailabilityText</strong>
                        </div>
                    </div>

                    <div class="mt-5 flex flex-wrap gap-3">
                        @if (canManageQuality)
                        {
                            <a asp-controller="DoughQuality"
                               asp-action="Review"
                               asp-route-referenceDate="@Model.TargetDate.ToString("yyyy-MM-dd")"
                               asp-route-currentStatus="@candidate.CurrentStatus"
                               class="inline-flex items-center justify-center gap-2 h-12 px-5 rounded-xl border border-outline-variant text-on-surface font-bold hover:bg-white no-underline">
                                <span class="material-symbols-outlined">verified</span>
                                Keep / Review Later
                            </a>
                        }

                        @if (canReball)
                        {
                            <a asp-controller="DoughQuality"
                               asp-action="Reball"
                               asp-route-recordId="@candidate.DoughBatchQualityRecordId"
                               asp-route-referenceDate="@Model.TargetDate.ToString("yyyy-MM-dd")"
                               class="inline-flex items-center justify-center gap-2 h-12 px-5 rounded-xl bg-primary text-on-primary font-bold hover:opacity-90 transition-opacity no-underline">
                                <span class="material-symbols-outlined">sync</span>
                                Reball
                            </a>
                        }

                        @if (canManageQuality)
                        {
                            <a asp-controller="DoughQuality"
                               asp-action="Discard"
                               asp-route-recordId="@candidate.DoughBatchQualityRecordId"
                               asp-route-referenceDate="@Model.TargetDate.ToString("yyyy-MM-dd")"
                               class="inline-flex items-center justify-center gap-2 h-12 px-5 rounded-xl border border-error text-error font-bold hover:bg-error-container no-underline">
                                <span class="material-symbols-outlined">delete</span>
                                Discard
                            </a>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>
