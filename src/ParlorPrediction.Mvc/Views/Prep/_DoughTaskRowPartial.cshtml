@model DoughTaskViewModel

<tr>
    <td>
        <div class="task-main">
            <strong>@Model.PrepItemName</strong>
            <span>@Model.PrepStationName station</span>
        </div>
    </td>
    <td>@Model.AssignedRole</td>
    <td>@Model.RecommendedQuantityText</td>
    <td>@Model.CompletedQuantityText</td>
    <td>
        <span class="status-pill @(Model.Status == "Completed" ? "status-pill--success" : "status-pill--neutral")">
            @Model.Status
        </span>
        @if (Model.CompletedAtUtc.HasValue)
        {
            <div class="task-timestamp">@Model.CompletedAtUtc.Value.ToLocalTime().ToString("MMM d, h:mm tt")</div>
        }
    </td>
    <td class="text-end">
        @if (Model.CanComplete)
        {
            <form asp-action="CompleteTask"
                  asp-controller="Prep"
                  method="post"
                  class="task-complete-form"
                  hx-post="@Url.Action("CompleteTask", "Prep")"
                  hx-target="#dough-prep-workspace"
                  hx-swap="outerHTML"
                  data-dough-quantity-form
                  data-dough-quantity-preview-mode="completed"
                  data-swal-confirm
                  data-confirm-title="Complete dough task?"
                  data-confirm-text="This will mark the dough task as completed for the current date.">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PrepTaskId" value="@Model.PrepTaskId" />
                <input type="hidden" name="TargetDate" value="@Model.TaskDate.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="HistoricalWeeksToUse" value="@Model.HistoricalWeeksToUse" />
                <input type="hidden" value="@Model.TaskType" data-dough-task-type />
                <div class="task-form-grid">
                    @if (Model.RestrictCompletionUnit)
                    {
                        <input type="hidden" name="CompletionType" value="@Model.DefaultCompletionUnit" data-dough-quantity-unit />
                        <input type="text"
                               value="@Model.DefaultCompletionUnit"
                               class="form-control form-control-sm"
                               readonly />
                    }
                    else
                    {
                        <select name="CompletionType"
                                class="form-select form-select-sm"
                                data-dough-quantity-unit
                                aria-label="Completion type">
                            <option value="Balls">Dough Balls</option>
                            <option value="Cases">Cases</option>
                            <option value="FullLoads">Full Loads</option>
                        </select>
                    }
                    <input name="QuantityValue"
                           type="number"
                           min="1"
                           value="@Model.SuggestedCompletionQuantityValue"
                           class="form-control form-control-sm"
                           data-dough-quantity-value
                           placeholder="Quantity done"
                           aria-label="Completed quantity" />
                    <input name="Notes"
                           type="text"
                           maxlength="500"
                           class="form-control form-control-sm"
                           placeholder="Optional kitchen note" />
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                        <i class="fa-solid fa-check me-1"></i>
                        Mark Done
                    </button>
                </div>
                <div class="inline-hint task-form-help">
                    <i class="fa-solid fa-circle-info"></i>
                    <span data-dough-quantity-preview>@Model.CompletionPreviewText</span>
                </div>
            </form>
        }
        else
        {
            <span class="inline-hint">Nothing else needed here</span>
        }
    </td>
</tr>
