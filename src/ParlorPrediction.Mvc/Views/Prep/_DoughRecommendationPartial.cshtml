@model DoughRecommendationViewModel?
@{
    var page = ViewData["DoughPrepPage"] as DoughPrepPageViewModel;
}

<section class="rounded-[28px] border border-outline-variant bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
        <div class="max-w-4xl">
            <p class="m-0 text-sm font-extrabold uppercase tracking-[0.2em] text-on-surface-variant">Manager Guidance</p>
            <h2 class="mt-2 text-3xl font-black tracking-[-0.04em] text-primary">Save the recommendation only after the kitchen picture makes sense.</h2>
            <p class="mt-3 text-lg leading-8 text-on-surface-variant">
                Keep this manager-only area below the operational cards so kitchen staff can focus on work first.
            </p>
        </div>

        @if (Model is not null)
        {
            <span class="inline-flex rounded-full bg-primary-fixed px-4 py-2 text-sm font-bold uppercase tracking-[0.08em] text-primary">
                @(Model.IsPersisted ? "Saved snapshot" : "Fresh calculation")
            </span>
        }
    </div>

    @if (Model is null)
    {
        <div class="mt-6 rounded-[22px] border border-dashed border-outline-variant bg-surface-container-low p-6 text-lg text-on-surface-variant">
            No dough guidance is loaded yet. Managers can recalculate above and then decide whether to save a snapshot or create a dough load task.
        </div>
    }
    else
    {
        <div class="mt-6 grid gap-5 xl:grid-cols-[1.5fr_.9fr]">
            <article class="rounded-[22px] border border-outline-variant bg-surface-container-low p-6">
                <h3 class="m-0 text-2xl font-bold tracking-[-0.03em] text-on-surface">Recommendation summary</h3>
                <p class="mt-4 mb-0 text-lg leading-8 text-on-surface-variant">@Model.Reason</p>

                @if (Model.ActionPlanSteps.Count > 0)
                {
                    <ul class="mt-5 space-y-3 text-lg text-on-surface-variant">
                        @foreach (var step in Model.ActionPlanSteps)
                        {
                            <li class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-primary">subdirectory_arrow_right</span>
                                <span>@step</span>
                            </li>
                        }
                    </ul>
                }
            </article>

            <article class="rounded-[22px] border border-outline-variant bg-white p-6">
                <div class="space-y-4">
                    @if (Model.CanSaveRecommendation)
                    {
                        <form asp-action="SaveDoughRecommendation"
                              asp-controller="Prep"
                              method="post"
                              hx-post="@Url.Action("SaveDoughRecommendation", "Prep")"
                              hx-target="#dough-prep-workspace"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="targetDate" value="@Model.RecommendationDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="historicalWeeksToUse" value="@Model.HistoricalWeeksToUse" />
                            <button type="submit" class="w-full h-touch-target-min rounded-xl bg-primary text-on-primary text-lg font-bold hover:opacity-90 transition-opacity">
                                Save This Guidance
                            </button>
                        </form>
                    }

                    @if (Model.CanCreateTask && Model.RecommendationId.HasValue)
                    {
                        <form asp-action="CreateDoughTask"
                              asp-controller="Prep"
                              method="post"
                              hx-post="@Url.Action("CreateDoughTask", "Prep")"
                              hx-target="#dough-prep-workspace"
                              hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="recommendationId" value="@Model.RecommendationId.Value" />
                            <input type="hidden" name="targetDate" value="@Model.RecommendationDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="historicalWeeksToUse" value="@Model.HistoricalWeeksToUse" />
                            <button type="submit" class="w-full h-touch-target-min rounded-xl border-2 border-primary bg-white text-primary text-lg font-bold hover:bg-primary-fixed transition-colors">
                                Turn Into Dough Load Task
                            </button>
                        </form>
                    }

                    @if (Model.TaskAlreadyExists)
                    {
                        <div class="rounded-[18px] bg-surface-container-low p-4 text-on-surface-variant">
                            A dough load task already exists for this saved guidance.
                        </div>
                    }

                    <div class="rounded-[18px] bg-surface-container-low p-4">
                        <p class="m-0 text-sm font-extrabold uppercase tracking-[0.18em] text-on-surface-variant">Snapshot math</p>
                        <p class="mt-3 mb-0 text-base leading-7 text-on-surface">Required: @Model.RequiredBalls balls</p>
                        <p class="mt-2 mb-0 text-base leading-7 text-on-surface">Available in snapshot: @Model.AvailableBalls balls</p>
                        <p class="mt-2 mb-0 text-base leading-7 text-on-surface">Already completed through ball work: @Model.CompletedBalls balls</p>
                    </div>
                </div>
            </article>
        </div>
    }
</section>
