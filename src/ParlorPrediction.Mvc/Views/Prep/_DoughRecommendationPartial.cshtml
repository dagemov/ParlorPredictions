@model DoughRecommendationViewModel?

<section class="content-card content-card--padded dq-recommendation-card">
    <div class="section-heading">
        <span class="eyebrow">Daily Dough Snapshot</span>
        <h2>Dough guidance for the selected day</h2>
        @if (Model is null)
        {
            <p class="dq-section-copy">No dough guidance is loaded for this date yet.</p>
        }
        else if (Model.IsPersisted)
        {
            <p class="dq-section-copy">This saved dough snapshot is ready for the kitchen team to review, print later, or turn into a prep task when the manager is ready.</p>
        }
        else
        {
            <p class="dq-section-copy">This dough guidance is only in memory right now. Save it if you want to keep a record for the team.</p>
        }
    </div>

    @if (Model is null)
    {
        <div class="empty-state">
            <i class="fa-regular fa-lightbulb"></i>
            <span>Managers can calculate dough guidance from the controls above.</span>
        </div>
    }
    else
    {
        <div class="dq-pill-row">
            <span class="status-pill @(Model.IsPersisted ? "status-pill--success" : "status-pill--info")">
                @(Model.IsPersisted ? "Saved For The Team" : "Just Calculated")
            </span>
            <span class="status-pill @(Model.ShouldMakeDough ? "status-pill--warning" : "status-pill--neutral")">
                @(Model.ShouldMakeDough ? "Mix Dough Today" : "No New Mixing Needed")
            </span>
            <span class="status-pill @(Model.ShouldBallDough ? "status-pill--warning" : "status-pill--neutral")">
                @(Model.ShouldBallDough ? "Ball Ready Dough" : "No Extra Balling Right Now")
            </span>
            @if (Model.UsesShortFermentationException)
            {
                <span class="status-pill status-pill--info">Summer Event Timing In Play</span>
            }
        </div>

        <div class="dq-summary-grid">
            <article class="dq-summary-card dq-summary-card--need">
                <div>
                    <span class="dq-summary-card__label">Need Today</span>
                    <p class="dq-summary-card__helper">What service needs today</p>
                </div>
                <div class="dq-summary-card__value-row">
                    <span class="dq-summary-card__value">@Model.RequiredBalls</span>
                    <span class="dq-summary-card__unit">balls</span>
                </div>
                <div class="dq-summary-card__bar">
                    <span></span>
                </div>
            </article>
            <article class="dq-summary-card dq-summary-card--available">
                <div>
                    <span class="dq-summary-card__label">Current Dough Available</span>
                    <p class="dq-summary-card__helper">Real dough counted on or before @Model.RecommendationDate.ToString("MMM d")</p>
                </div>
                <div class="dq-summary-card__value-row">
                    <span class="dq-summary-card__value">@Model.AvailableBalls</span>
                    <span class="dq-summary-card__unit">balls</span>
                </div>
                <div class="dq-summary-card__bar">
                    <span></span>
                </div>
            </article>
            <article class="dq-summary-card dq-summary-card--completed">
                <div>
                    <span class="dq-summary-card__label">Dough Already Done</span>
                    <p class="dq-summary-card__helper">Finished through dough tasks for this day</p>
                </div>
                <div class="dq-summary-card__value-row">
                    <span class="dq-summary-card__value">@Model.CompletedBalls</span>
                    <span class="dq-summary-card__unit">balls</span>
                </div>
                <div class="dq-summary-card__bar">
                    <span></span>
                </div>
            </article>
            <article class="dq-summary-card dq-summary-card--missing">
                <div>
                    <span class="dq-summary-card__label">Need To Make</span>
                    <p class="dq-summary-card__helper">Still missing for today</p>
                </div>
                <div class="dq-summary-card__value-row">
                    <span class="dq-summary-card__value">@Model.MissingBalls</span>
                    <span class="dq-summary-card__unit">balls</span>
                </div>
                <div class="dq-summary-card__bar">
                    <span></span>
                </div>
            </article>
        </div>

        @if (Model.ShouldBallDough || Model.UsesShortFermentationException)
        {
            <div class="dq-guidance-banner">
                <span class="dq-guidance-banner__eyebrow">Operational attention</span>
                <h3>
                    @if (Model.ShouldBallDough)
                    {
                        @:Ball ready dough today
                    }
                    else
                    {
                        @:Short-timing event window in play
                    }
                </h3>
                <p>
                    @if (Model.ShouldBallDough)
                    {
                        @:Some dough is already mixed and should be balled now so the kitchen stays ahead.
                    }
                    else
                    {
                        @:The guidance includes shorter fermentation timing because of event timing and seasonal heat conditions.
                    }
                </p>
            </div>
        }

        <div class="dq-manager-banner">
            <span class="dq-manager-banner__eyebrow">System guidance</span>
            <h3>Why the system is saying this</h3>
            <p>@Model.Reason</p>
            @if (Model.SavedAtUtc.HasValue)
            {
                <small>Saved @Model.SavedAtUtc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</small>
            }
        </div>

        <div class="recommendation-note mt-3">
            <h3>Recommended Action Plan</h3>
            <ul class="info-list mb-0">
                @foreach (var step in Model.ActionPlanSteps)
                {
                    <li>@step</li>
                }
            </ul>
        </div>

        <div class="dq-action-stack">
            @if (Model.CanSaveRecommendation)
            {
                <form asp-action="SaveDoughRecommendation"
                      asp-controller="Prep"
                      method="post"
                      hx-post="@Url.Action("SaveDoughRecommendation", "Prep")"
                      hx-target="#dough-prep-workspace"
                      hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="targetDate" value="@Model.RecommendationDate.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="historicalWeeksToUse" value="@Model.HistoricalWeeksToUse" />
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-regular fa-floppy-disk me-2"></i>
                        Save This Dough Guidance
                    </button>
                </form>
            }

            @if (Model.CanCreateTask && Model.RecommendationId.HasValue)
            {
                <form asp-action="CreateDoughTask"
                      asp-controller="Prep"
                      method="post"
                      hx-post="@Url.Action("CreateDoughTask", "Prep")"
                      hx-target="#dough-prep-workspace"
                      hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="recommendationId" value="@Model.RecommendationId.Value" />
                    <input type="hidden" name="targetDate" value="@Model.RecommendationDate.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="historicalWeeksToUse" value="@Model.HistoricalWeeksToUse" />
                    <button type="submit" class="btn btn-dark">
                        <i class="fa-solid fa-list-check me-2"></i>
                        Turn Into Dough Task
                    </button>
                </form>
            }
        </div>

        @if (Model.TaskAlreadyExists)
        {
            <p class="inline-hint dq-inline-note mt-3 mb-0">
                <i class="fa-solid fa-circle-info me-2"></i>
                A dough task already exists for this saved guidance.
            </p>
        }
    }
</section>
