@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    var statusType = TempData["SessionStatusType"] as string;
    var statusMessage = TempData["SessionStatusMessage"] as string;
}

<section class="auth-shell pp-auth-shell">
    <div class="auth-card">
        <div class="pp-auth-brand">
            <span class="pp-auth-brand__mark">PP</span>
            <div class="pp-auth-brand__copy">
                <strong>Parlor Prediction</strong>
                <small>Kitchen workflow access</small>
            </div>
        </div>

        <div class="section-heading">
            <span class="eyebrow">Parlor Prep Access</span>
            <h1>Sign in to continue</h1>
            <p>Use your Parlor account to open Dough Prep, review recommendations, and complete kitchen tasks.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="alert alert-@statusType" role="alert">
                @statusMessage
            </div>
        }

        <form asp-action="Login" asp-controller="Session" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div>
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
            </div>

            <div>
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" placeholder="Password" />
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>
                Sign In
            </button>
        </form>

        <p class="pp-auth-footer">
            Don&apos;t have an account?
            <a asp-action="Register" asp-controller="Session">Register here.</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
