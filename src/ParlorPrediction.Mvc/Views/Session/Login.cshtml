@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<section class="auth-shell">
    <div class="auth-card">
        <div class="section-heading">
            <span class="eyebrow">Parlor Prep Access</span>
            <h1>Sign in to continue</h1>
            <p>Use your Parlor account to open Prep, review dough recommendations, and track task completion.</p>
        </div>

        <form asp-action="Login" asp-controller="Session" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-floating">
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <label asp-for="Email"></label>
            </div>

            <div class="form-floating">
                <input asp-for="Password" class="form-control" placeholder="Password" />
                <label asp-for="Password"></label>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>
                Sign In
            </button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
